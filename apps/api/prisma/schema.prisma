  ACCOUNTS_RECEIVABLE
  SALES_REVENUE
  COST_OF_GOODS
  INVENTORY
  UDHAR_RECEIVABLE
}

enum LedgerEntryType {
  DEBIT
  CREDIT
}

enum InventoryStockState {
  AVAILABLE
  RESERVED
  ALLOCATED
  IN_TRANSIT
  DAMAGED
  LOST
  RETURNED
  QUARANTINE
  BLOCKED
  EXPIRED
  ADJUSTMENT_PENDING
  COUNTING
}

enum AdjustmentReason {
  MANUAL_COUNT
