generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  OWNER
  ADMIN
  MANAGER
  CASHIER
  VIEWER
}

enum ShopStatus {
  ACTIVE
  SUSPENDED
  LOCKED
  ARCHIVED
  DELETED
}

enum PaymentMode {
  CASH
  UPI
  CARD
  UDHAR
  SPLIT
}

enum InvoiceType {
  SALE
  SALES_RETURN
}

enum InvoiceStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

enum UdharTransactionType {
  CREDIT
  PAYMENT
  ADJUSTMENT
  WRITEOFF
}

enum InventoryChangeType {
  SALE
  PURCHASE
  RETURN_IN
  RETURN_OUT
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
  DAMAGE
  OPENING
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  RECEIVED
  CANCELLED
}

enum StockTransferStatus {
  PENDING
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

enum ProductUnit {
  PCS
  KG
  GM
  LTR
  ML
  BOX
  PACK
  DOZEN
  BUNDLE
}

enum ProductStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  INACTIVE
  ARCHIVED
  SOFT_DELETED
}

enum ProductType {
  SIMPLE
  VARIABLE
  BUNDLE
  COMBO
  SERVICE
  DIGITAL
  SERIALIZED
  BATCH_MANAGED
  PERISHABLE
  RAW_MATERIAL
  SEMI_FINISHED
  FINISHED_GOODS
  SUBSCRIPTION
}

enum RevisionStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  PUBLISHED
  SUPERSEDED
  ARCHIVED
  REJECTED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum GstRate {
  ZERO
  FIVE
  TWELVE
  EIGHTEEN
  TWENTYEIGHT
}

enum NotificationType {
  LOW_STOCK
  UDHAR_OVERDUE
  SHIFT_NOT_CLOSED
  PAYMENT_RECEIVED
  LARGE_DISCOUNT
  SUSPICIOUS_ACTIVITY
}

enum DriftStatus {
  DETECTED
  REPAIRED
  FAILED
}

enum LedgerAccount {
  CASH
  ACCOUNTS_RECEIVABLE
  SALES_REVENUE
  COST_OF_GOODS
  INVENTORY
  UDHAR_RECEIVABLE
}

enum LedgerEntryType {
  DEBIT
  CREDIT
}

model Shop {
  id        String     @id @default(cuid())
  name      String
  address   String?
  city      String?
  state     String?
  pincode   String?
  phone     String?
  email     String?
  logoUrl   String?
  status    ShopStatus @default(ACTIVE)
  ownerId   String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  isDeleted Boolean    @default(false)
  deletedAt DateTime?

  owner    User          @relation("ShopOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  settings ShopSettings?

  users                User[]
  categories           Category[]
  products             Product[]
  productBatches       ProductBatch[]
  suppliers            Supplier[]
  customers            Customer[]
  shifts               Shift[]
  invoices             Invoice[]
  udharTransactions    UdharTransaction[]
  inventoryLogs        InventoryLog[]
  auditLogs            AuditLog[]
  purchaseOrders       PurchaseOrder[]
  stockTransfersIn     StockTransfer[]       @relation("TransferDestinationShop")
  stockTransfersOut    StockTransfer[]       @relation("TransferSourceShop")
  notifications        Notification[]
  ledgerTransactions   LedgerTransaction[]
  inventoryDriftLogs   InventoryDriftLog[]
  invitations          Invitation[]
  brands               Brand[]
  manufacturers        Manufacturer[]
  variantAttributes    VariantAttribute[]
  productVariants      ProductVariant[]
  productBarcodes      ProductBarcode[]
  productAttributes    ProductAttribute[]
  productTags          ProductTag[]
  productImages        ProductImage[]
  productPriceTiers    ProductPriceTier[]
  productRelationships ProductRelationship[]
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  password       String
  name           String
  phone          String?
  role           Role
  isActive       Boolean   @default(true)
  shopId         String
  isLocked       Boolean   @default(false)
  lockedUntil    DateTime?
  lastLoginAt    DateTime?
  lastLoginIp    String?
  failedAttempts Int       @default(0)
  tokenVersion   Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  isDeleted      Boolean   @default(false)
  deletedAt      DateTime?

  shop              Shop               @relation(fields: [shopId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ownedShop         Shop?              @relation("ShopOwner")
  refreshTokens     RefreshToken[]
  loginAttempts     LoginAttempt[]
  shiftsOpened      Shift[]            @relation("ShiftOpenedBy")
  shiftsClosed      Shift[]            @relation("ShiftClosedBy")
  invoices          Invoice[]          @relation("InvoiceCashier")
  udharTransactions UdharTransaction[] @relation("UdharRecordedBy")
  inventoryLogs     InventoryLog[]     @relation("InventoryRecordedBy")
  auditLogs         AuditLog[]         @relation("AuditUser")

  @@index([shopId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Invitation {
  id        String   @id @default(cuid())
  email     String
  role      Role
  shopId    String
  token     String   @unique
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([email])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  userId    String
  ipAddress String
  userAgent String?
  success   Boolean
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
  @@index([userId])
}

model Category {
  id           String    @id @default(cuid())
  name         String
  slug         String    @default("")
  shopId       String
  parentId     String?
  path         String    @default("/")
  depth        Int       @default(0)
  sortOrder    Int       @default(0)
  isActive     Boolean   @default(true)
  imageUrl     String?
  productCount Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?

  shop          Shop       @relation(fields: [shopId], references: [id], onDelete: Restrict)
  parent        Category?  @relation("SubCategories", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subCategories Category[] @relation("SubCategories")
  products      Product[]

  @@unique([shopId, name, deletedAt])
  @@index([shopId])
  @@index([parentId])
  @@index([shopId, path])
  @@index([shopId, isActive])
}

model Product {
  id          String        @id @default(cuid())
  name        String
  slug        String        @default("")
  sku         String
  barcode     String?
  description String?       @db.Text
  type        ProductType   @default(SIMPLE)
  status      ProductStatus @default(ACTIVE)

  costPrice       Decimal  @db.Decimal(10, 2)
  sellingPrice    Decimal  @db.Decimal(10, 2)
  mrp             Decimal  @db.Decimal(10, 2)
  wholesalePrice  Decimal  @db.Decimal(10, 2)
  minSellingPrice Decimal? @db.Decimal(10, 2)
  maxDiscountPct  Decimal? @db.Decimal(5, 2)

  gstRate  GstRate @default(EIGHTEEN)
  cessRate Decimal @default(0) @db.Decimal(5, 2)
  hsnCode  String?

  currentPublishedRevId String? @unique
  currentDraftRevId     String? @unique

  categoryId     String?
  shopId         String
  supplierId     String?
  brandId        String?
  manufacturerId String?

  currentStock Decimal @default(0) @db.Decimal(10, 3)
  stockVersion Int     @default(0)
  reorderPoint Decimal @default(10) @db.Decimal(10, 3)
  reorderQty   Decimal @default(50) @db.Decimal(10, 3)

  totalUnitsSold Decimal   @default(0) @db.Decimal(10, 3)
  totalRevenue   Decimal   @default(0) @db.Decimal(12, 2)
  lastSoldAt     DateTime?
  analyticsClass String?

  unit             ProductUnit
  hasExpiry        Boolean     @default(false)
  defaultShelfLife Int?
  isActive         Boolean     @default(true)
  imageUrl         String?
  aliases          String?     @db.Text
  searchKeywords   String?     @db.Text

  version    Int       @default(1)
  createdBy  String?
  updatedBy  String?
  approvedBy String?
  approvedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  shop         Shop          @relation(fields: [shopId], references: [id], onDelete: Restrict)
  category     Category?     @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  supplier     Supplier?     @relation(fields: [supplierId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  brand        Brand?        @relation(fields: [brandId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  manufacturer Manufacturer? @relation(fields: [manufacturerId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  batches            ProductBatch[]
  invoiceItems       InvoiceItem[]
  inventoryLogs      InventoryLog[]
  purchaseOrderItems PurchaseOrderItem[]
  stockTransferItems StockTransferItem[]
  inventoryDriftLogs InventoryDriftLog[]

  revisions       ProductRevision[]
  branches        RevisionBranch[]
  variants        ProductVariant[]
  barcodes        ProductBarcode[]
  images          ProductImage[]
  attributes      ProductAttribute[]
  tags            ProductTag[]
  priceTiers      ProductPriceTier[]
  relationsSource ProductRelationship[] @relation("RelationSource")
  relationsTarget ProductRelationship[] @relation("RelationTarget")
  skuHistory      SkuHistory[]

  @@unique([shopId, sku, deletedAt])
  @@index([shopId, status])
  @@index([shopId, categoryId])
  @@index([shopId, brandId])
  @@index([shopId, type])
  @@fulltext([name, aliases, searchKeywords])
}

model ProductBatch {
  id           String    @id @default(cuid())
  productId    String
  shopId       String
  batchNumber  String
  expiryDate   DateTime?
  costPrice    Decimal   @db.Decimal(10, 2)
  mrp          Decimal   @db.Decimal(10, 2)
  sellingPrice Decimal   @db.Decimal(10, 2)
  initialStock Decimal   @db.Decimal(10, 3)
  currentStock Decimal   @db.Decimal(10, 3)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?

  product Product @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  shop    Shop    @relation(fields: [shopId], references: [id], onDelete: Restrict)

  @@index([productId])
  @@index([shopId, expiryDate])
}

model Supplier {
  id        String    @id @default(cuid())
  name      String
  phone     String
  email     String?
  gstin     String?
  address   String?
  city      String?
  state     String?
  shopId    String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  shop           Shop            @relation(fields: [shopId], references: [id], onDelete: Restrict)
  products       Product[]
  purchaseOrders PurchaseOrder[]

  @@unique([shopId, phone, deletedAt])
  @@index([shopId])
}

model Customer {
  id                 String    @id @default(cuid())
  name               String
  phone              String
  email              String?
  address            String?
  city               String?
  state              String?
  shopId             String
  creditLimit        Decimal   @default(5000) @db.Decimal(10, 2)
  outstandingBalance Decimal   @default(0) @db.Decimal(10, 2)
  totalPurchases     Decimal   @default(0) @db.Decimal(10, 2)
  totalPaid          Decimal   @default(0) @db.Decimal(10, 2)
  lastPurchaseAt     DateTime?
  lastPaymentAt      DateTime?
  tags               String?
  notes              String?
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  isDeleted          Boolean   @default(false)
  deletedAt          DateTime?

  shop              Shop               @relation(fields: [shopId], references: [id], onDelete: Restrict)
  invoices          Invoice[]
  udharTransactions UdharTransaction[]

  @@unique([shopId, phone, deletedAt])
  @@index([shopId])
}

model Shift {
  id            String      @id @default(cuid())
  shopId        String
  openedById    String
  closedById    String?
  openingCash   Decimal     @db.Decimal(10, 2)
  closingCash   Decimal?    @db.Decimal(10, 2)
  expectedCash  Decimal     @default(0) @db.Decimal(10, 2)
  totalSales    Decimal     @default(0) @db.Decimal(10, 2)
  totalReceipts Decimal     @default(0) @db.Decimal(10, 2)
  cashSales     Decimal     @default(0) @db.Decimal(10, 2)
  upiSales      Decimal     @default(0) @db.Decimal(10, 2)
  cardSales     Decimal     @default(0) @db.Decimal(10, 2)
  udharSales    Decimal     @default(0) @db.Decimal(10, 2)
  status        ShiftStatus @default(OPEN)
  openedAt      DateTime    @default(now())
  closedAt      DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  isDeleted     Boolean     @default(false)
  deletedAt     DateTime?

  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Restrict)
  openedBy User      @relation("ShiftOpenedBy", fields: [openedById], references: [id], onDelete: Restrict)
  closedBy User?     @relation("ShiftClosedBy", fields: [closedById], references: [id], onDelete: Restrict)
  invoices Invoice[]

  @@index([shopId, status])
  @@index([openedById])
  @@index([closedById])
  @@index([shopId, openedAt])
}

model Invoice {
  id             String        @id @default(cuid())
  invoiceNumber  String
  idempotencyKey String
  financialYear  String
  shopId         String
  customerId     String?
  cashierId      String
  originalId     String?
  subtotal       Decimal       @db.Decimal(10, 2)
  taxableAmount  Decimal       @db.Decimal(10, 2)
  cgstAmount     Decimal       @db.Decimal(10, 2)
  sgstAmount     Decimal       @db.Decimal(10, 2)
  igstAmount     Decimal       @default(0) @db.Decimal(10, 2)
  taxAmount      Decimal       @db.Decimal(10, 2)
  discountAmount Decimal       @db.Decimal(10, 2)
  roundOffAmount Decimal       @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal       @db.Decimal(10, 2)
  paidAmount     Decimal       @db.Decimal(10, 2)
  udharAmount    Decimal       @default(0) @db.Decimal(10, 2)
  changeAmount   Decimal       @db.Decimal(10, 2)
  paymentMode    PaymentMode
  paymentRef     String?
  isInterState   Boolean       @default(false)
  type           InvoiceType   @default(SALE)
  status         InvoiceStatus
  cancelReason   String?
  notes          String?
  shiftId        String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  isDeleted      Boolean       @default(false)
  deletedAt      DateTime?

  shop               Shop                @relation(fields: [shopId], references: [id], onDelete: Restrict)
  customer           Customer?           @relation(fields: [customerId], references: [id], onDelete: Restrict)
  cashier            User                @relation("InvoiceCashier", fields: [cashierId], references: [id], onDelete: Restrict)
  shift              Shift?              @relation(fields: [shiftId], references: [id], onDelete: Restrict)
  items              InvoiceItem[]
  udharTransactions  UdharTransaction[]
  inventoryLogs      InventoryLog[]
  originalInvoice    Invoice?            @relation("InvoiceReturns", fields: [originalId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  returnInvoices     Invoice[]           @relation("InvoiceReturns")
  ledgerTransactions LedgerTransaction[]

  @@unique([shopId, financialYear, invoiceNumber])
  @@unique([shopId, idempotencyKey])
  @@index([shopId, status])
  @@index([customerId])
  @@index([cashierId])
  @@index([shiftId])
  @@index([originalId])
  @@index([shopId, createdAt])
}

model InvoiceItem {
  id              String      @id @default(cuid())
  invoiceId       String
  productId       String
  productName     String
  productSku      String
  quantity        Decimal     @db.Decimal(10, 3)
  unit            ProductUnit
  costPrice       Decimal     @db.Decimal(10, 2)
  sellingPrice    Decimal     @db.Decimal(10, 2)
  mrp             Decimal     @db.Decimal(10, 2)
  discountPercent Decimal     @default(0) @db.Decimal(5, 2)
  gstRate         GstRate
  cgstAmount      Decimal     @db.Decimal(10, 2)
  sgstAmount      Decimal     @db.Decimal(10, 2)
  igstAmount      Decimal     @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal     @db.Decimal(10, 2)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  isDeleted       Boolean     @default(false)
  deletedAt       DateTime?

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([invoiceId])
  @@index([productId])
}

model UdharTransaction {
  id            String               @id @default(cuid())
  customerId    String
  invoiceId     String?
  shopId        String
  type          UdharTransactionType
  amount        Decimal              @db.Decimal(10, 2)
  balanceBefore Decimal              @db.Decimal(10, 2)
  balanceAfter  Decimal              @db.Decimal(10, 2)
  notes         String?
  recordedById  String
  createdAt     DateTime             @default(now())

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  invoice    Invoice? @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  shop       Shop     @relation(fields: [shopId], references: [id], onDelete: Restrict)
  recordedBy User     @relation("UdharRecordedBy", fields: [recordedById], references: [id], onDelete: Restrict)

  @@index([customerId, createdAt])
  @@index([shopId, type])
  @@index([invoiceId])
  @@index([recordedById])
}

model InventoryLog {
  id             String              @id @default(cuid())
  productId      String
  shopId         String
  type           InventoryChangeType
  quantityBefore Decimal             @db.Decimal(10, 3)
  quantityChange Decimal             @db.Decimal(10, 3)
  quantityAfter  Decimal             @db.Decimal(10, 3)
  invoiceId      String?
  notes          String?
  recordedById   String
  createdAt      DateTime            @default(now())

  product    Product  @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  shop       Shop     @relation(fields: [shopId], references: [id], onDelete: Restrict)
  invoice    Invoice? @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  recordedBy User     @relation("InventoryRecordedBy", fields: [recordedById], references: [id], onDelete: Restrict)

  @@index([productId, createdAt])
  @@index([shopId, type])
  @@index([invoiceId])
  @@index([recordedById])
}

model AuditLog {
  id         String   @id @default(cuid())
  shopId     String?
  userId     String
  action     String
  entity     String
  entityId   String
  beforeData Json?
  afterData  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  shop Shop? @relation(fields: [shopId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user User  @relation("AuditUser", fields: [userId], references: [id], onDelete: Restrict)

  @@index([shopId, entity])
  @@index([userId, createdAt])
  @@index([shopId, createdAt])
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  shopId      String
  supplierId  String
  orderNumber String
  status      PurchaseOrderStatus @default(DRAFT)
  totalAmount Decimal             @db.Decimal(10, 2)
  notes       String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  isDeleted   Boolean             @default(false)
  deletedAt   DateTime?

  shop     Shop                @relation(fields: [shopId], references: [id], onDelete: Restrict)
  supplier Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  items    PurchaseOrderItem[]

  @@unique([shopId, orderNumber, deletedAt])
  @@index([shopId, status])
  @@index([supplierId])
}

model PurchaseOrderItem {
  id              String    @id @default(cuid())
  purchaseOrderId String
  productId       String
  quantity        Decimal   @db.Decimal(10, 3)
  unitCost        Decimal   @db.Decimal(10, 2)
  cgstAmount      Decimal   @default(0) @db.Decimal(10, 2)
  sgstAmount      Decimal   @default(0) @db.Decimal(10, 2)
  igstAmount      Decimal   @default(0) @db.Decimal(10, 2)
  totalCost       Decimal   @db.Decimal(10, 2)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  isDeleted       Boolean   @default(false)
  deletedAt       DateTime?

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([purchaseOrderId])
  @@index([productId])
}

model StockTransfer {
  id                String              @id @default(cuid())
  sourceShopId      String
  destinationShopId String
  status            StockTransferStatus @default(PENDING)
  totalItems        Int
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  isDeleted         Boolean             @default(false)
  deletedAt         DateTime?

  sourceShop      Shop                @relation("TransferSourceShop", fields: [sourceShopId], references: [id], onDelete: Restrict)
  destinationShop Shop                @relation("TransferDestinationShop", fields: [destinationShopId], references: [id], onDelete: Restrict)
  items           StockTransferItem[]

  @@index([sourceShopId])
  @@index([destinationShopId])
}

model StockTransferItem {
  id              String    @id @default(cuid())
  stockTransferId String
  productId       String
  quantity        Decimal   @db.Decimal(10, 3)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  isDeleted       Boolean   @default(false)
  deletedAt       DateTime?

  stockTransfer StockTransfer @relation(fields: [stockTransferId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([stockTransferId])
  @@index([productId])
}

model Notification {
  id        String           @id @default(cuid())
  shopId    String
  entityId  String?
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  isDeleted Boolean          @default(false)
  deletedAt DateTime?

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Restrict)

  @@index([shopId, isRead])
}

model OutboxEvent {
  id          String    @id @default(cuid())
  type        String
  payload     Json
  status      String    @default("PENDING") // PENDING, DONE, FAILED
  error       String?
  retryCount  Int       @default(0)
  createdAt   DateTime  @default(now())
  processedAt DateTime?

  @@index([status, createdAt])
}

model LedgerTransaction {
  id           String          @id @default(cuid())
  shopId       String
  invoiceId    String?
  account      LedgerAccount
  type         LedgerEntryType
  amount       Decimal         @db.Decimal(10, 2)
  balanceAfter Decimal         @db.Decimal(10, 2)
  description  String?
  createdAt    DateTime        @default(now())

  shop    Shop     @relation(fields: [shopId], references: [id], onDelete: Restrict)
  invoice Invoice? @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  @@index([shopId, createdAt])
  @@index([invoiceId])
  @@index([shopId, account])
}

model InventoryDriftLog {
  id            String      @id @default(cuid())
  shopId        String
  productId     String
  redisValue    Decimal     @db.Decimal(10, 3)
  databaseValue Decimal     @db.Decimal(10, 3)
  difference    Decimal     @db.Decimal(10, 3)
  status        DriftStatus @default(DETECTED)
  createdAt     DateTime    @default(now())
  resolvedAt    DateTime?

  shop    Shop    @relation(fields: [shopId], references: [id], onDelete: Restrict)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([shopId, createdAt])
  @@index([productId])
}

// -----------------------------------------------------------------------------
// EPIC 3: PRODUCT DOMAIN ENHANCEMENTS
// -----------------------------------------------------------------------------

model Brand {
  id        String   @id @default(cuid())
  name      String
  slug      String   @default("")
  shopId    String
  logoUrl   String?
  aliases   String?  @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)

  shop     Shop      @relation(fields: [shopId], references: [id])
  products Product[]

  @@unique([shopId, name])
  @@index([shopId])
}

model Manufacturer {
  id        String   @id @default(cuid())
  name      String
  shopId    String
  country   String?
  state     String?
  gstin     String?
  contact   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop     Shop      @relation(fields: [shopId], references: [id])
  products Product[]

  @@unique([shopId, name])
  @@index([shopId])
}

model ProductRevision {
  id        String @id @default(cuid())
  productId String
  branchId  String
  shopId    String

  versionNumber Int
  parentRevId   String?

  isSnapshot  Boolean
  data        Json
  contentHash String

  status       RevisionStatus @default(DRAFT)
  scheduledFor DateTime?
  publishedAt  DateTime?

  authorId      String
  commitMessage String?
  createdAt     DateTime @default(now())

  product        Product            @relation(fields: [productId], references: [id])
  branch         RevisionBranch     @relation(fields: [branchId], references: [id])
  parentRevision ProductRevision?   @relation("RevisionHistory", fields: [parentRevId], references: [id])
  childRevisions ProductRevision[]  @relation("RevisionHistory")
  approvals      RevisionApproval[]
  diffs          RevisionDiff[]     @relation("DiffTarget")

  @@unique([productId, versionNumber])
  @@index([shopId, productId, status])
  @@index([scheduledFor])
}

model RevisionBranch {
  id        String   @id @default(cuid())
  productId String
  name      String
  baseRevId String
  isMerged  Boolean  @default(false)
  createdAt DateTime @default(now())

  product   Product           @relation(fields: [productId], references: [id])
  revisions ProductRevision[]

  @@unique([productId, name])
}

model RevisionApproval {
  id               String         @id @default(cuid())
  revisionId       String
  reviewerId       String
  status           ApprovalStatus
  comments         String?
  digitalSignature String?
  createdAt        DateTime       @default(now())
  resolvedAt       DateTime?

  revision ProductRevision @relation(fields: [revisionId], references: [id])

  @@index([revisionId])
}

model RevisionDiff {
  id          String   @id @default(cuid())
  sourceRevId String
  targetRevId String
  patch       Json
  createdAt   DateTime @default(now())

  targetRevision ProductRevision @relation("DiffTarget", fields: [targetRevId], references: [id])

  @@unique([sourceRevId, targetRevId])
}

model VariantAttribute {
  id        String @id @default(cuid())
  shopId    String
  name      String
  slug      String
  sortOrder Int    @default(0)

  shop   Shop                    @relation(fields: [shopId], references: [id])
  values VariantAttributeValue[]

  @@unique([shopId, slug])
  @@index([shopId])
}

model VariantAttributeValue {
  id          String  @id @default(cuid())
  attributeId String
  value       String
  slug        String
  colorHex    String?
  sortOrder   Int     @default(0)

  attribute VariantAttribute          @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  variants  ProductVariantAttribute[]

  @@unique([attributeId, slug])
  @@index([attributeId])
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  shopId    String
  sku       String
  barcode   String?

  costPrice    Decimal? @db.Decimal(10, 2)
  sellingPrice Decimal? @db.Decimal(10, 2)
  mrp          Decimal? @db.Decimal(10, 2)

  currentStock Decimal @default(0) @db.Decimal(10, 3)
  stockVersion Int     @default(0)

  imageUrl String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)

  product    Product                   @relation(fields: [productId], references: [id])
  shop       Shop                      @relation(fields: [shopId], references: [id])
  attributes ProductVariantAttribute[]

  @@unique([shopId, sku, isDeleted])
  @@index([productId])
  @@index([shopId])
}

model ProductVariantAttribute {
  id               String @id @default(cuid())
  variantId        String
  attributeValueId String

  variant        ProductVariant        @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attributeValue VariantAttributeValue @relation(fields: [attributeValueId], references: [id])

  @@unique([variantId, attributeValueId])
  @@index([variantId])
}

model ProductBarcode {
  id        String   @id @default(cuid())
  productId String
  shopId    String
  barcode   String
  type      String
  isPrimary Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  shop    Shop    @relation(fields: [shopId], references: [id])

  @@unique([shopId, barcode])
  @@index([productId])
}

model ProductAttribute {
  id        String @id @default(cuid())
  productId String
  shopId    String
  key       String
  value     String
  dataType  String @default("STRING")
  sortOrder Int    @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  shop    Shop    @relation(fields: [shopId], references: [id])

  @@unique([productId, key])
  @@index([shopId, key])
}

model ProductTag {
  id        String @id @default(cuid())
  productId String
  shopId    String
  tag       String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  shop    Shop    @relation(fields: [shopId], references: [id])

  @@unique([productId, tag])
  @@index([shopId, tag])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  shopId    String
  url       String
  altText   String?
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  sizeBytes Int?
  width     Int?
  height    Int?
  hash      String?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  shop    Shop    @relation(fields: [shopId], references: [id])

  @@index([productId])
}

model ProductPriceTier {
  id          String   @id @default(cuid())
  productId   String
  shopId      String
  minQuantity Decimal  @db.Decimal(10, 3)
  maxQuantity Decimal? @db.Decimal(10, 3)
  price       Decimal  @db.Decimal(10, 2)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  shop    Shop    @relation(fields: [shopId], references: [id])

  @@index([productId, minQuantity])
  @@index([shopId])
}

model ProductRelationship {
  id              String   @id @default(cuid())
  sourceProductId String
  targetProductId String
  shopId          String
  type            String
  sortOrder       Int      @default(0)
  quantity        Decimal? @db.Decimal(10, 3)
  createdAt       DateTime @default(now())

  sourceProduct Product @relation("RelationSource", fields: [sourceProductId], references: [id])
  targetProduct Product @relation("RelationTarget", fields: [targetProductId], references: [id])
  shop          Shop    @relation(fields: [shopId], references: [id])

  @@unique([sourceProductId, targetProductId, type])
  @@index([sourceProductId, type])
  @@index([shopId])
}

model SkuHistory {
  id        String   @id @default(cuid())
  productId String
  oldSku    String
  newSku    String
  reason    String
  changedBy String
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
}

model ShopSettings {
  id               String   @id @default(cuid())
  shopId           String   @unique
  currency         String   @default("INR")
  timezone         String   @default("Asia/Kolkata")
  gstin            String?
  locale           String   @default("en-IN")
  businessCategory String?
  invoiceNumbering String   @default("PREFIX-YYYY-SEQ")
  financialYear    String   @default("APR-MAR")
  subscriptionPlan String   @default("FREE")
  taxProfile       String   @default("DEFAULT")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
}
