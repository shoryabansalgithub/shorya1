  attribute VariantAttribute          @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  variants  ProductVariantAttribute[]

  @@unique([attributeId, slug])
  @@index([attributeId])
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  shopId    String
  sku       String
  barcode   String?

  costPrice    Decimal? @db.Decimal(10, 2)
  sellingPrice Decimal? @db.Decimal(10, 2)
  mrp          Decimal? @db.Decimal(10, 2)

  currentStock Decimal @default(0) @db.Decimal(10, 3)
  stockVersion Int     @default(0)

  imageUrl String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)

  product    Product                   @relation(fields: [productId], references: [id])
  shop       Shop                      @relation(fields: [shopId], references: [id])
  attributes ProductVariantAttribute[]

  variantIdentity   VariantIdentity?
  globalBarcodes    Barcode[]
  packageIdentities PackageIdentity[]
  qrCodes           QrCode[]
  mediaReferences   MediaReference[]

  @@unique([shopId, sku, isDeleted])
  @@index([productId])
  @@index([shopId])
}

model ProductVariantAttribute {
  id               String @id @default(cuid())
  variantId        String
  attributeValueId String

  variant        ProductVariant        @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attributeValue VariantAttributeValue @relation(fields: [attributeValueId], references: [id])

  @@unique([variantId, attributeValueId])
  @@index([variantId])
}

model ProductBarcode {
  id        String   @id @default(cuid())
  productId String
  shopId    String
  barcode   String
  type      String
  isPrimary Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  shop    Shop    @relation(fields: [shopId], references: [id])

  @@unique([shopId, barcode])
  @@index([productId])
}

model ProductAttribute {
  id        String @id @default(cuid())
  productId String
  shopId    String
  key       String
  value     String
  dataType  String @default("STRING")
  sortOrder Int    @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  shop    Shop    @relation(fields: [shopId], references: [id])

  @@unique([productId, key])
  @@index([shopId, key])
}

model ProductTag {
  id        String @id @default(cuid())
  productId String
  shopId    String
  tag       String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  shop    Shop    @relation(fields: [shopId], references: [id])

  @@unique([productId, tag])
  @@index([shopId, tag])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  shopId    String
  url       String
  altText   String?
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  sizeBytes Int?
  width     Int?
  height    Int?
  hash      String?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  shop    Shop    @relation(fields: [shopId], references: [id])

  @@index([productId])
}

model ProductPriceTier {
  id          String   @id @default(cuid())
  productId   String
  shopId      String
  minQuantity Decimal  @db.Decimal(10, 3)
  maxQuantity Decimal? @db.Decimal(10, 3)
  price       Decimal  @db.Decimal(10, 2)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  shop    Shop    @relation(fields: [shopId], references: [id])

  @@index([productId, minQuantity])
  @@index([shopId])
}

model ProductRelationship {
  id              String   @id @default(cuid())
  sourceProductId String
  targetProductId String
  shopId          String
  type            String
  sortOrder       Int      @default(0)
  quantity        Decimal? @db.Decimal(10, 3)
  createdAt       DateTime @default(now())

  sourceProduct Product @relation("RelationSource", fields: [sourceProductId], references: [id])
  targetProduct Product @relation("RelationTarget", fields: [targetProductId], references: [id])
  shop          Shop    @relation(fields: [shopId], references: [id])

  @@unique([sourceProductId, targetProductId, type])
  @@index([sourceProductId, type])
  @@index([shopId])
}

model SkuHistory {
  id        String   @id @default(cuid())
  productId String
  oldSku    String
  newSku    String
  reason    String
  changedBy String
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
}

model ShopSettings {
  id               String   @id @default(cuid())
  shopId           String   @unique
  currency         String   @default("INR")
  timezone         String   @default("Asia/Kolkata")
  gstin            String?
  locale           String   @default("en-IN")
  businessCategory String?
  invoiceNumbering String   @default("PREFIX-YYYY-SEQ")
  financialYear    String   @default("APR-MAR")
  subscriptionPlan String   @default("FREE")
  taxProfile       String   @default("DEFAULT")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model ProductIdentity {
  id                String   @id @default(cuid())
  shopId            String
  productId         String   @unique
  globalProductId   String?  @unique
  internalProductId String?  @unique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  shop    Shop    @relation(fields: [shopId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

model VariantIdentity {
  id        String   @id @default(cuid())
  shopId    String
  variantId String   @unique
  sku       String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop    Shop           @relation(fields: [shopId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])
}

model PackageIdentity {
  id          String   @id @default(cuid())
  shopId      String
  productId   String?
  variantId   String?
  packageType String
  quantity    Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shop     Shop            @relation(fields: [shopId], references: [id])
  product  Product?        @relation(fields: [productId], references: [id])
  variant  ProductVariant? @relation(fields: [variantId], references: [id])
  barcodes Barcode[]
}

model Barcode {
  id     String        @id @default(cuid())
  shopId String
  code   String
  format BarcodeFormat
  status BarcodeStatus @default(ACTIVE)

  productId String?
  variantId String?
  packageId String?

  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop    Shop             @relation(fields: [shopId], references: [id])
  product Product?         @relation(fields: [productId], references: [id])
  variant ProductVariant?  @relation(fields: [variantId], references: [id])
  package PackageIdentity? @relation(fields: [packageId], references: [id])
  history BarcodeHistory[]

  @@unique([shopId, code])
  @@index([productId])
  @@index([variantId])
}

model BarcodeHistory {
  id          String   @id @default(cuid())
  shopId      String
  barcodeId   String
  oldCode     String?
  newCode     String
  reason      String
  changedById String
  createdAt   DateTime @default(now())

  shop      Shop    @relation(fields: [shopId], references: [id])
  barcode   Barcode @relation(fields: [barcodeId], references: [id])
  changedBy User    @relation(fields: [changedById], references: [id])
}

model BarcodeTemplate {
  id        String   @id @default(cuid())
  shopId    String
  name      String
  type      String
  content   String   @db.Text
  width     Decimal  @db.Decimal(10, 2)
  height    Decimal  @db.Decimal(10, 2)
  unit      String   @default("mm")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop      Shop              @relation(fields: [shopId], references: [id])
  printJobs BarcodePrintJob[]
}

model BarcodePrintJob {
  id            String    @id @default(cuid())
  shopId        String
  templateId    String
  printerId     String?
  status        String
  quantity      Int
  requestedById String
  createdAt     DateTime  @default(now())
  completedAt   DateTime?

  shop        Shop            @relation(fields: [shopId], references: [id])
  template    BarcodeTemplate @relation(fields: [templateId], references: [id])
  requestedBy User            @relation(fields: [requestedById], references: [id])
}

model QrCode {
  id      String @id @default(cuid())
  shopId  String
  code    String @unique
  payload String @db.Text
  type    String

  productId String?
  variantId String?

  createdAt DateTime @default(now())

  shop    Shop            @relation(fields: [shopId], references: [id])
  product Product?        @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
  MODEL3D
}

enum MediaStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  ARCHIVED
}

model MediaAsset {
  id           String      @id @default(cuid())
  shopId       String
  hash         String // SHA-256 for deduplication
  mimeType     String
  extension    String
  sizeBytes    Int
  originalName String
  status       MediaStatus @default(PUBLISHED)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  isDeleted    Boolean     @default(false)

  shop       Shop             @relation(fields: [shopId], references: [id])
  metadata   MediaMetadata?
  storage    MediaStorage?
  versions   MediaVersion[]
  references MediaReference[]
  thumbanils MediaThumbnail[]
  audits     MediaAudit[]
  tags       MediaTag[]       @relation("AssetTags")

  @@unique([shopId, hash]) // Deduplication constraint
}

model MediaMetadata {
  id          String @id @default(cuid())
  assetId     String @unique
  width       Int?
  height      Int?
  durationSec Int?
  exifData    Json?

  asset MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model MediaStorage {
  id       String  @id @default(cuid())
  shopId   String
  assetId  String  @unique
  provider String // LOCAL, S3, R2
  bucket   String?
  path     String
  cdnUrl   String?

  shop  Shop       @relation(fields: [shopId], references: [id])
  asset MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model MediaThumbnail {
  id       String  @id @default(cuid())
  shopId   String
  assetId  String
  sizeKey  String // 100px, 300px, 600px
  path     String
  cdnUrl   String?
  width    Int
  height   Int
  mimeType String

  shop  Shop       @relation(fields: [shopId], references: [id])
  asset MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, sizeKey])
}

model MediaVersion {
  id        String   @id @default(cuid())
  shopId    String
  assetId   String
  version   Int
  path      String
  createdAt DateTime @default(now())

  shop  Shop       @relation(fields: [shopId], references: [id])
  asset MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model MediaReference {
  id         String  @id @default(cuid())
  shopId     String
  assetId    String
  productId  String?
  variantId  String?
  categoryId String?
  brandId    String?

  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)

  shop    Shop            @relation(fields: [shopId], references: [id])
  asset   MediaAsset      @relation(fields: [assetId], references: [id], onDelete: Cascade)
  product Product?        @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])
  // category    Category?  @relation(fields: [categoryId], references: [id])
  // brand       Brand?     @relation(fields: [brandId], references: [id])

  @@index([productId])
  @@index([variantId])
}

model MediaTag {
  id     String @id @default(cuid())
  shopId String
  name   String // e.g. Hero, Packaging, Manual

  shop   Shop         @relation(fields: [shopId], references: [id])
  assets MediaAsset[] @relation("AssetTags")

  @@unique([shopId, name])
}

model MediaAudit {
  id        String   @id @default(cuid())
  shopId    String
  assetId   String
  userId    String
  action    String // UPLOAD, COMPRESS, TAG, DELETE
  timestamp DateTime @default(now())

  shop  Shop       @relation(fields: [shopId], references: [id])
  asset MediaAsset @relation(fields: [assetId], references: [id])
  user  User       @relation(fields: [userId], references: [id])
}

enum SearchEntityType {
  PRODUCT
  VARIANT
  CATEGORY
  BRAND
}

enum IndexStatus {
  PENDING
  INDEXING
  COMPLETED
  FAILED
}

model SearchHistory {
  id        String   @id @default(cuid())
  shopId    String
  userId    String?
  query     String
  resultCount Int
  durationMs Int
  createdAt DateTime @default(now())

  shop      Shop     @relation(fields: [shopId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])

  @@index([shopId, query])
}

model SavedSearch {
  id        String   @id @default(cuid())
  shopId    String
  userId    String
  name      String
  query     String
  filters   Json?
  createdAt DateTime @default(now())

  shop      Shop     @relation(fields: [shopId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model SearchSynonym {
  id        String   @id @default(cuid())
  shopId    String
  term      String
  synonyms  String   // Comma separated list of synonyms
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  shop      Shop     @relation(fields: [shopId], references: [id])

  @@unique([shopId, term])
}

model SearchBoost {
  id        String   @id @default(cuid())
  shopId    String
  queryTerm String
  entityId  String   // e.g. Product ID
  entityType SearchEntityType
  score     Float    @default(1.0)
  createdAt DateTime @default(now())

  shop      Shop     @relation(fields: [shopId], references: [id])

  @@unique([shopId, queryTerm, entityId])
}

model SearchAnalytics {
  id           String   @id @default(cuid())
  shopId       String
  query        String
  searchCount  Int      @default(1)
  clickCount   Int      @default(0)
  zeroResults  Int      @default(0)
  date         DateTime @db.Date

  shop      Shop     @relation(fields: [shopId], references: [id])

  @@unique([shopId, query, date])
}

model SearchClick {
  id        String   @id @default(cuid())
  shopId    String
  userId    String?
  query     String
  entityId  String
  entityType SearchEntityType
  position  Int
  createdAt DateTime @default(now())

  shop      Shop     @relation(fields: [shopId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])
}

model SearchIndexStatus {
  id        String   @id @default(cuid())
  shopId    String
  entityType SearchEntityType
  status    IndexStatus @default(PENDING)
  lastRun   DateTime?
  durationMs Int?
  error     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop      Shop     @relation(fields: [shopId], references: [id])

  @@unique([shopId, entityType])
}

enum ValidationSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
  BLOCKING
}

model ProductQualityScore {
  id        String   @id @default(cuid())
  productId String   @unique
  shopId    String
  score     Int      @default(0) // 0-100
  missingFields Json?
  suggestions   Json?
  calculatedAt DateTime @default(now())
  
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  shop      Shop     @relation(fields: [shopId], references: [id])
}

model ProductValidationIssue {
  id        String   @id @default(cuid())
  productId String
  shopId    String
  stage     String   // e.g. "PRICING", "MEDIA", "SEO"
  field     String?  // e.g. "sellingPrice"
  message   String
  severity  ValidationSeverity @default(WARNING)
  createdAt DateTime @default(now())

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  shop      Shop     @relation(fields: [shopId], references: [id])

  @@index([productId])
}

model ValidationRule {
  id          String   @id @default(cuid())
  shopId      String
  ruleKey     String   // e.g. "PRICE_GREATER_THAN_MRP"
  description String
  isEnabled   Boolean  @default(true)
  severity    ValidationSeverity @default(ERROR)
  config      Json?    // Optional thresholds/limits
  
  shop        Shop     @relation(fields: [shopId], references: [id])

  @@unique([shopId, ruleKey])
}

model DuplicateCandidate {
  id          String   @id @default(cuid())
  shopId      String
  sourceId    String
  targetId    String
  score       Float    // e.g. 0.95 for 95% match
  reasons     Json?    // Why it was flagged (e.g. name similarity, same SKU)
  status      String   @default("PENDING") // PENDING, RESOLVED, IGNORED
  createdAt   DateTime @default(now())

  shop        Shop     @relation(fields: [shopId], references: [id])
  source      Product  @relation("DuplicateSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target      Product  @relation("DuplicateTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([shopId, sourceId, targetId])
  @@index([sourceId])
}

enum JobStatus {
  PENDING
  VALIDATING
  PROCESSING
  COMPLETED
  PARTIAL_SUCCESS
  FAILED
  CANCELLED
  ROLLING_BACK
  ROLLED_BACK
}

enum ImportMode {
  CREATE_ONLY
  UPDATE_ONLY
  UPSERT
  MERGE
  REPLACE
}

model ImportJob {
  id              String      @id @default(cuid())
  shopId          String
  fileName        String
  fileSize        Int
  fileUrl         String      // Local or S3 path
  format          String      // CSV, XLSX, JSON, XML
  mode            ImportMode  @default(UPSERT)
  status          JobStatus   @default(PENDING)
  
  totalRows       Int         @default(0)
  validRows       Int         @default(0)
  errorRows       Int         @default(0)
  createdCount    Int         @default(0)
  updatedCount    Int         @default(0)
  skippedCount    Int         @default(0)

  errorReportUrl  String?
  mappingId       String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  shop            Shop        @relation(fields: [shopId], references: [id])
  mapping         ImportMapping? @relation(fields: [mappingId], references: [id])
  rows            ImportJobRow[]
}

model ImportJobRow {
  id              String      @id @default(cuid())
  importJobId     String
  rowNumber       Int
  rawData         Json        // The raw parsed row
  status          String      @default("PENDING") // PENDING, SUCCESS, ERROR
  errors          Json?       // Validation errors for this row
  actionTaken     String?     // CREATED, UPDATED, SKIPPED
  createdAt       DateTime    @default(now())

  importJob       ImportJob   @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@index([importJobId, status])
}

model ImportMapping {
  id              String      @id @default(cuid())
  shopId          String
  name            String
  mappingConfig   Json        // e.g. { "Product Name": "name", "Selling Price": "variants.0.sellingPrice" }
  isDefault       Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  shop            Shop        @relation(fields: [shopId], references: [id])
  jobs            ImportJob[]
}

model ExportJob {
  id              String      @id @default(cuid())
  shopId          String
  format          String      // CSV, XLSX, JSON, XML
  status          JobStatus   @default(PENDING)
  filters         Json?       // e.g. { categoryId: "123" }
  exportedCount   Int         @default(0)
  fileUrl         String?
  error           String?     @db.Text
  
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  shop            Shop        @relation(fields: [shopId], references: [id])
}

model RollbackRecord {
  id              String      @id @default(cuid())
  shopId          String
  entityId        String
  entityType      String      // PRODUCT, VARIANT, etc
  action          String      // IMPORT_UPDATE, IMPORT_CREATE
  jobId           String
  previousData    Json?       // The snapshot before update
  createdAt       DateTime    @default(now())

  shop            Shop        @relation(fields: [shopId], references: [id])
  
  @@index([shopId, jobId])
}

model ProductEventLog {
  id            String    @id @default(cuid())
  shopId        String
  tenantId      String?
  eventId       String    @unique
  eventType     String
  eventVersion  String    @default("v1")
  entityId      String?
  entityType    String?
  timestamp     DateTime  @default(now())
  correlationId String?
  causationId   String?
  actorId       String?
  payload       Json
  metadata      Json?

  shop          Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, eventType])
  @@index([entityId, entityType])
}

model WebhookEndpoint {
  id            String    @id @default(cuid())
  shopId        String
  url           String
  secret        String    // Used for HMAC signature
  events        Json      // Array of event types (e.g. ["ProductCreated", "PriceChanged"])
  isActive      Boolean   @default(true)
  description   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  shop          Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  deliveries    WebhookDelivery[]

  @@index([shopId, isActive])
}

model WebhookDelivery {
  id            String    @id @default(cuid())
  endpointId    String
  eventId       String
  eventType     String
  payload       Json
  status        String    // SUCCESS, FAILED
  statusCode    Int?
  errorMessage  String?   @db.Text
  latencyMs     Int?
  createdAt     DateTime  @default(now())

  endpoint      WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId, status])
}

model DeadLetterEvent {
  id            String    @id @default(cuid())
  shopId        String
  eventId       String
  eventType     String
  payload       Json
  failureReason String?   @db.Text
  retryCount    Int       @default(0)
  sourceQueue   String?   // e.g. "webhook-delivery" or "internal-event-router"
  status        String    @default("PENDING") // PENDING, RESOLVED, IGNORED
  createdAt     DateTime  @default(now())

  shop          Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, status])
}

// -----------------------------------------------------------------------------
// PHASE 3.2.1: ENTERPRISE INVENTORY DOMAIN
// -----------------------------------------------------------------------------

model InventoryItem {
  id               String              @id @default(cuid())
  shopId           String
  productId        String
  variantId        String?
  locationId       String              @default("DEFAULT")

  onHand           Decimal             @default(0) @db.Decimal(12, 3)
  reserved         Decimal             @default(0) @db.Decimal(12, 3)
  allocated        Decimal             @default(0) @db.Decimal(12, 3)
  damaged          Decimal             @default(0) @db.Decimal(12, 3)
  lost             Decimal             @default(0) @db.Decimal(12, 3)
  inTransit        Decimal             @default(0) @db.Decimal(12, 3)

  reorderPoint     Decimal             @default(10) @db.Decimal(12, 3)
  reorderQty       Decimal             @default(50) @db.Decimal(12, 3)
  safetyStock      Decimal             @default(0) @db.Decimal(12, 3)
  maxStock         Decimal             @default(99999) @db.Decimal(12, 3)
  minStock         Decimal             @default(0) @db.Decimal(12, 3)

  isNegativeAllowed Boolean            @default(false)
  status           InventoryStockState @default(AVAILABLE)
  version          Int                 @default(0)

  lastCountedAt    DateTime?
  lastAdjustedAt   DateTime?
  createdBy        String?
  updatedBy        String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  isDeleted        Boolean             @default(false)
  deletedAt        DateTime?

  shop             Shop                @relation(fields: [shopId], references: [id], onDelete: Restrict)
  product          Product             @relation(fields: [productId], references: [id], onDelete: Restrict)
  location         Location            @relation(fields: [locationId], references: [id], onDelete: Restrict)

  adjustments      InventoryAdjustment[]
  movements        InventoryMovement[]
  stockLedgerEntries StockLedgerEntry[]
  stockSnapshots     StockSnapshot[]
  snapshots        InventorySnapshot[]
  thresholds       InventoryThreshold[]
  alerts           InventoryAlert[]
  reservationAllocations ReservationAllocation[]
  stockCountItems    StockCountItem[]
  adjustmentRequests AdjustmentRequest[]
  batchStocks        BatchStock[]

  @@unique([shopId, productId, variantId, locationId])
  @@index([shopId, status])
  @@index([productId])
  @@index([shopId, locationId])
}

model InventoryAdjustment {
  id               String           @id @default(cuid())
  shopId           String
  inventoryItemId  String
  reason           AdjustmentReason
  quantityBefore   Decimal          @db.Decimal(12, 3)
  quantityChange   Decimal          @db.Decimal(12, 3)
  quantityAfter    Decimal          @db.Decimal(12, 3)
  notes            String?          @db.Text
  correlationId    String?
  causationId      String?
  createdBy        String
  createdAt        DateTime         @default(now())

  shop             Shop             @relation(fields: [shopId], references: [id], onDelete: Restrict)
  inventoryItem    InventoryItem    @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@index([inventoryItemId, createdAt])
  @@index([shopId, reason])
  @@index([correlationId])
}

model InventoryMovement {
  id               String              @id @default(cuid())
  shopId           String
  inventoryItemId  String
  fromState        InventoryStockState
  toState          InventoryStockState
  quantity         Decimal             @db.Decimal(12, 3)
  referenceType    String              // SALE, PURCHASE, TRANSFER, ADJUSTMENT, RETURN
  referenceId      String?
  correlationId    String?
  causationId      String?
  notes            String?             @db.Text
  createdBy        String?
  createdAt        DateTime            @default(now())

  shop             Shop                @relation(fields: [shopId], references: [id], onDelete: Restrict)
  inventoryItem    InventoryItem       @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@index([inventoryItemId, createdAt])
  @@index([shopId, referenceType])
  @@index([correlationId])
}

model InventorySnapshot {
  id               String        @id @default(cuid())
  shopId           String
  inventoryItemId  String
  onHand           Decimal       @db.Decimal(12, 3)
  reserved         Decimal       @db.Decimal(12, 3)
  allocated        Decimal       @db.Decimal(12, 3)
  damaged          Decimal       @db.Decimal(12, 3)
  lost             Decimal       @db.Decimal(12, 3)
  inTransit        Decimal       @db.Decimal(12, 3)
  snapshotReason   String?       // SCHEDULED, MANUAL, AUDIT
  createdBy        String?
  createdAt        DateTime      @default(now())

  shop             Shop          @relation(fields: [shopId], references: [id], onDelete: Restrict)
  inventoryItem    InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@index([inventoryItemId, createdAt])
  @@index([shopId, createdAt])
}

model InventoryThreshold {
  id               String        @id @default(cuid())
  shopId           String
  inventoryItemId  String
  alertType        InventoryAlertType
  thresholdValue   Decimal       @db.Decimal(12, 3)
  isActive         Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  shop             Shop          @relation(fields: [shopId], references: [id], onDelete: Restrict)
  inventoryItem    InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@index([inventoryItemId])
  @@index([shopId, alertType])
}

model InventoryAlert {
  id               String             @id @default(cuid())
  shopId           String
  inventoryItemId  String
  alertType        InventoryAlertType
  message          String
  currentValue     Decimal            @db.Decimal(12, 3)
  thresholdValue   Decimal?           @db.Decimal(12, 3)
  isResolved       Boolean            @default(false)
  resolvedAt       DateTime?
  resolvedBy       String?
  createdAt        DateTime           @default(now())

  shop             Shop               @relation(fields: [shopId], references: [id], onDelete: Restrict)
  inventoryItem    InventoryItem      @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@index([shopId, isResolved])
  @@index([inventoryItemId, alertType])
}

// -----------------------------------------------------------------------------
// PHASE 3.2.2: ENTERPRISE WAREHOUSE MANAGEMENT
// -----------------------------------------------------------------------------

model Warehouse {
  id               String            @id @default(cuid())
  shopId           String
  code             String
  name             String
  type             WarehouseType     @default(MAIN)
  
  // Physical constraints
  maxWeightKg      Decimal?          @db.Decimal(12, 3)
  maxVolumeM3      Decimal?          @db.Decimal(12, 3)
  maxSkuCount      Int?
  
  address          String?           @db.Text
  city             String?
  state            String?
  pincode          String?
  country          String?
  contactName      String?
  contactPhone     String?

  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  isDeleted        Boolean           @default(false)
  deletedAt        DateTime?

  shop             Shop              @relation(fields: [shopId], references: [id], onDelete: Restrict)
  locations        Location[]
  goodsReceipts    GoodsReceipt[]
  purchaseReturns  PurchaseReturn[]

  @@unique([shopId, code, deletedAt])
  @@index([shopId, isActive])
  @@index([type])
}

model Location {
  id               String            @id @default(cuid())
  shopId           String
  warehouseId      String
  parentId         String?
  type             LocationType
  code             String
  path             String            // Materialized Path: /WH1/Z1/A3/R2/S1/B4
  depth            Int               @default(0)
  
  status           LocationStatus    @default(ACTIVE)

  // Physical constraints
  maxWeightKg      Decimal?          @db.Decimal(12, 3)
  maxVolumeM3      Decimal?          @db.Decimal(12, 3)
  
  // Current occupancy (calculated via BullMQ asynchronously or sync on events)
  currentWeightKg  Decimal           @default(0) @db.Decimal(12, 3)
  currentVolumeM3  Decimal           @default(0) @db.Decimal(12, 3)
  
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  isDeleted        Boolean           @default(false)
  deletedAt        DateTime?

  shop             Shop              @relation(fields: [shopId], references: [id], onDelete: Restrict)
  warehouse        Warehouse         @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  
  // Hierarchical relations
  parent           Location?         @relation("LocationHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children         Location[]        @relation("LocationHierarchy")
  
  inventoryItems   InventoryItem[]
  capacityLogs     LocationCapacityLog[]

  @@unique([shopId, warehouseId, code, deletedAt])
  @@index([shopId, warehouseId])
  @@index([parentId])
  @@index([shopId, path]) // Critical for fast prefix querying (LIKE '/WH1/Z1/%')
  @@index([shopId, type])
}

model LocationCapacityLog {
  id               String            @id @default(cuid())
  shopId           String
  locationId       String
  oldWeightKg      Decimal           @db.Decimal(12, 3)
  newWeightKg      Decimal           @db.Decimal(12, 3)
  oldVolumeM3      Decimal           @db.Decimal(12, 3)
  newVolumeM3      Decimal           @db.Decimal(12, 3)
  reason           String?
  createdAt        DateTime          @default(now())

  shop             Shop              @relation(fields: [shopId], references: [id], onDelete: Restrict)
  location         Location          @relation(fields: [locationId], references: [id], onDelete: Restrict)

  @@index([locationId, createdAt])
  @@index([shopId])
}

// -----------------------------------------------------------------------------
// PHASE 3.2.3: ENTERPRISE STOCK LEDGER ENGINE
// -----------------------------------------------------------------------------

model StockLedgerEntry {
  id               String            @id @default(cuid())
  shopId           String
  inventoryItemId  String
  
  movementType     StockMovementType
  quantity         Decimal           @db.Decimal(12, 3) // Positive for IN, Negative for OUT
  unitCost         Decimal?          @db.Decimal(12, 2) // Optional financial valuation
  
  referenceType    String?           // e.g., 'INVOICE', 'PO', 'ADJUSTMENT', 'TRANSFER'
  referenceId      String?
  documentId       String?
  correlationId    String?           // Ties multiple entries into a single double-entry transaction

  balanceAfter     Decimal           @db.Decimal(12, 3) // Immutable snapshot of balance after this movement
  
  createdBy        String?
  createdAt        DateTime          @default(now())

  shop             Shop              @relation(fields: [shopId], references: [id], onDelete: Restrict)
  inventoryItem    InventoryItem     @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  // This index is extremely critical for Ledger summation queries and time-travel
  @@index([shopId, inventoryItemId, createdAt])
  @@index([referenceType, referenceId])
  @@index([correlationId])
}

model StockSnapshot {
  id               String            @id @default(cuid())
  shopId           String
  inventoryItemId  String
  
  periodEnd        DateTime          // The exact time this snapshot represents
  openingBalance   Decimal           @db.Decimal(12, 3)
  netChange        Decimal           @db.Decimal(12, 3)
  closingBalance   Decimal           @db.Decimal(12, 3)
  
  createdAt        DateTime          @default(now())

  shop             Shop              @relation(fields: [shopId], references: [id], onDelete: Restrict)
  inventoryItem    InventoryItem     @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@unique([shopId, inventoryItemId, periodEnd])
  @@index([shopId, periodEnd])
}

// -----------------------------------------------------------------------------
// PHASE 3.2.4: ENTERPRISE STOCK RESERVATION & ALLOCATION ENGINE
// -----------------------------------------------------------------------------

model StockReservation {
  id               String            @id @default(cuid())
  shopId           String
  
  source           ReservationSource @default(SYSTEM)
  referenceId      String?           // e.g., Sales Order ID, POS Cart ID
  
  status           ReservationStatus @default(CREATED)
  
  expiresAt        DateTime?         // Automatic release deadline
  releasedAt       DateTime?
  
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  shop             Shop              @relation(fields: [shopId], references: [id], onDelete: Restrict)
  items            ReservationItem[]

  @@index([shopId, status])
  @@index([expiresAt, status]) // Critical for the sweeping job
  @@index([referenceId])
}

model ReservationItem {
  id               String            @id @default(cuid())
  shopId           String
  reservationId    String
  
  productId        String
  variantId        String?
  
  requestedQuantity Decimal          @db.Decimal(12, 3)
  allocatedQuantity Decimal          @default(0) @db.Decimal(12, 3)
  
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  shop             Shop              @relation(fields: [shopId], references: [id], onDelete: Restrict)
  reservation      StockReservation  @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  product          Product           @relation(fields: [productId], references: [id], onDelete: Restrict)
  
  allocations      ReservationAllocation[]

  @@index([reservationId])
  @@index([productId, variantId])
}

model ReservationAllocation {
  id               String            @id @default(cuid())
  shopId           String
  reservationItemId String
  inventoryItemId  String
  
  allocatedQuantity Decimal          @db.Decimal(12, 3)
  status           AllocationStatus  @default(LOCKED)
  
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  shop             Shop              @relation(fields: [shopId], references: [id], onDelete: Restrict)
  reservationItem  ReservationItem   @relation(fields: [reservationItemId], references: [id], onDelete: Cascade)
  inventoryItem    InventoryItem     @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@index([reservationItemId])
  @@index([inventoryItemId])
}

// -----------------------------------------------------------------------------
// PHASE 3.2.5: ENTERPRISE INVENTORY ADJUSTMENT & STOCK COUNT ENGINE
// -----------------------------------------------------------------------------

model StockCountSession {
  id               String            @id @default(cuid())
  shopId           String
  warehouseId      String?           // Optional if count spans multiple warehouses
  
  type             CountType         @default(CYCLE_COUNT)
  status           CountSessionStatus @default(CREATED)
  
  assignedToUserId String?
  
  scheduledFor     DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  shop             Shop              @relation(fields: [shopId], references: [id], onDelete: Restrict)
  items            StockCountItem[]

  @@index([shopId, status])
  @@index([assignedToUserId])
}

model StockCountItem {
  id               String            @id @default(cuid())
  shopId           String
  sessionId        String
  inventoryItemId  String
  
  // Snapshotted at the exact moment the count begins to prevent variance skew if operations continue
  expectedQuantity Decimal           @db.Decimal(12, 3) 
  
  countedQuantity  Decimal?          @db.Decimal(12, 3)
  variance         Decimal?          @db.Decimal(12, 3) // countedQuantity - expectedQuantity
  
  notes            String?           @db.Text
  
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  shop             Shop              @relation(fields: [shopId], references: [id], onDelete: Restrict)
  session          StockCountSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  inventoryItem    InventoryItem     @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  adjustmentRequests AdjustmentRequest[]

  @@index([sessionId])
  @@index([inventoryItemId])
}

model AdjustmentRequest {
  id               String            @id @default(cuid())
  shopId           String
  inventoryItemId  String
  countItemId      String?           // Optional link back to the exact count item that found the variance
  
  reason           AdjustmentReason  @default(MANUAL_COUNT)
  requestedQuantityDelta Decimal     @db.Decimal(12, 3) // +5 or -2
  
  status           AdjustmentStatus  @default(PENDING_APPROVAL)
  
  requestedById    String?
  approvedById     String?
  approvedAt       DateTime?
  
  ledgerEntryId    String?           // Populated after posting to the Stock Ledger
  
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  shop             Shop              @relation(fields: [shopId], references: [id], onDelete: Restrict)
  inventoryItem    InventoryItem     @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  countItem        StockCountItem?   @relation(fields: [countItemId], references: [id], onDelete: SetNull)

  @@index([shopId, status])
  @@index([inventoryItemId])
}

// -----------------------------------------------------------------------------
// PHASE 3.2.6: ENTERPRISE BATCH, LOT & EXPIRY MANAGEMENT ENGINE
// -----------------------------------------------------------------------------

model Batch {
  id                String            @id @default(cuid())
  shopId            String
  
  productId         String
  variantId         String?
  
  batchNumber       String            // Internal batch number
  supplierLotNumber String?           // Original manufacturer lot number
  
  mfgDate           DateTime?         // Manufacturing Date
  expiryDate        DateTime?         // Expiry / Best Before Date
  
  type              BatchType         @default(PURCHASE)
  status            BatchStatus       @default(AVAILABLE)
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  shop              Shop              @relation(fields: [shopId], references: [id], onDelete: Restrict)
  product           Product           @relation(fields: [productId], references: [id], onDelete: Restrict, name: "EnterpriseBatches")
  
  batchStocks       BatchStock[]
  recalls           BatchRecall[]

  @@unique([shopId, batchNumber])
  @@index([shopId, status])
  @@index([expiryDate, status])       // Extremely critical for FEFO allocation & expiry sweeping
  @@index([productId, variantId])
}

model BatchStock {
  id                String            @id @default(cuid())
  shopId            String
  batchId           String
  inventoryItemId   String            // The physical bin where this batch resides
  
  quantity          Decimal           @db.Decimal(12, 3) // Actual amount of THIS batch in THIS bin
  reservedQuantity  Decimal           @default(0) @db.Decimal(12, 3)
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  shop              Shop              @relation(fields: [shopId], references: [id], onDelete: Restrict)
  batch             Batch             @relation(fields: [batchId], references: [id], onDelete: Restrict)
  inventoryItem     InventoryItem     @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@unique([batchId, inventoryItemId])
  @@index([inventoryItemId])
}

model BatchRecall {
  id                String            @id @default(cuid())
  shopId            String
  batchId           String
  
  reason            String            @db.Text
  status            RecallStatus      @default(ACTIVE)
  
  initiatedById     String?
  initiatedAt       DateTime          @default(now())
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  shop              Shop              @relation(fields: [shopId], references: [id], onDelete: Restrict)
  batch             Batch             @relation(fields: [batchId], references: [id], onDelete: Cascade)
  @@index([shopId, status])
  @@index([batchId])
}

// -----------------------------------------------------------------------------
// PHASE 3.2.8: ENTERPRISE INVENTORY ANALYTICS & INTELLIGENCE PLATFORM (CQRS)
// -----------------------------------------------------------------------------

model InventoryKpi {
  id                 String     @id @default(cuid())
  shopId             String
  productId          String
  date               DateTime   @db.Date // The date this KPI represents
  
  totalValue         Decimal    @db.Decimal(15, 4) // Financial value of stock
  turnoverRate       Decimal    @default(0) @db.Decimal(10, 4) // Sales / Avg Inventory
  daysOfInventory    Decimal    @default(0) @db.Decimal(10, 2) // How long stock will last
  stockoutRiskScore  Decimal    @default(0) @db.Decimal(5, 2)  // 0-100 risk score
  
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  shop               Shop       @relation(fields: [shopId], references: [id], onDelete: Restrict)
  product            Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([shopId, productId, date])
  @@index([shopId, date])
}

model InventoryClassification {
  id                 String     @id @default(cuid())
  shopId             String
  productId          String
  
  abcClass           AbcClass   @default(UNCLASSIFIED) // Value based
  xyzClass           XyzClass   @default(UNCLASSIFIED) // Volatility based
  
  calculatedAt       DateTime   @default(now())

  shop               Shop       @relation(fields: [shopId], references: [id], onDelete: Restrict)
  product            Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([shopId, productId])
  @@index([shopId, abcClass, xyzClass])
}

model InventoryRecommendation {
  id                 String             @id @default(cuid())
  shopId             String
  productId          String
  
  type               RecommendationType
  score              Decimal            @db.Decimal(5, 2) // 0-100 confidence score
  reason             String             @db.Text
  actionData         Json?              // e.g. { "suggestedQuantity": 50 }
  
  status             String             @default("ACTIVE") // ACTIVE, DISMISSED, ACTIONED
  
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Restrict)
  product            Product            @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([shopId, status])
  @@index([shopId, type])
}

// -----------------------------------------------------------------------------
// PHASE 3.2.9: ENTERPRISE EVENT DRIVEN ARCHITECTURE
// -----------------------------------------------------------------------------

model IdempotencyRecord {
  id               String   @id @default(cuid())
  eventId          String   // The ID of the OutboxEvent or incoming webhook
  consumerId       String   // e.g., 'InventoryProjectionWorker' or 'WebhookDispatcher'
  status           String   @default("PROCESSED")
  createdAt        DateTime @default(now())

  @@unique([eventId, consumerId])
}

model InventoryEventLog {
  id               String   @id @default(cuid())
  shopId           String
  eventType        String
  aggregateType    String
  aggregateId      String
  payload          Json
  version          String   @default("v1")
  publishedAt      DateTime @default(now())

  shop             Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, eventType])
  @@index([aggregateId])
}

// -----------------------------------------------------------------------------
// PHASE 3.3.1: ENTERPRISE SALES DOMAIN
// -----------------------------------------------------------------------------

enum SalesOrderStatus {
  DRAFT
  PENDING_CONFIRMATION
  CONFIRMED
  RESERVED
  PICKING
  PICKED
  PACKING
  PACKED
  READY_TO_SHIP
  SHIPPED
  DELIVERED
  READY_FOR_BILLING
  PARTIALLY_BILLED
  BILLED
  PARTIALLY_DELIVERED
  COMPLETED
  CANCELLED
  PARTIALLY_CANCELLED
  ON_HOLD
  REJECTED
  EXPIRED
  ARCHIVED
  FAILED
  RETURNED_PENDING
  SPLIT
}

model SalesOrder {
  id                 String             @id @default(cuid())
  orderNumber        String
  shopId             String
  tenantId           String?
  status             SalesOrderStatus   @default(DRAFT)
  customerId         String?            // Nullable for guest checkouts
  
  // Financials
  subTotal           Decimal            @db.Decimal(15, 4)
  taxTotal           Decimal            @db.Decimal(15, 4)
  cgstTotal          Decimal            @default(0) @db.Decimal(15, 4)
  sgstTotal          Decimal            @default(0) @db.Decimal(15, 4)
  igstTotal          Decimal            @default(0) @db.Decimal(15, 4)
  cessTotal          Decimal            @default(0) @db.Decimal(15, 4)
  discountTotal      Decimal            @db.Decimal(15, 4)
  grandTotal         Decimal            @db.Decimal(15, 4)
  paidAmount         Decimal            @default(0) @db.Decimal(15, 4)
  outstandingAmount  Decimal            @default(0) @db.Decimal(15, 4)
  currency           String             @default("USD")

  // Audit and Lifecycle
  version            Int                @default(1) // Optimistic locking
  deletedAt          DateTime?          // Soft delete
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  createdBy          String?
  updatedBy          String?

  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Restrict)
  
  lines              SalesOrderLine[]
  snapshots          SalesOrderSnapshot[]
  statusHistory      SalesOrderStatusHistory[]
  comments           SalesOrderComment[]
  auditLogs          SalesOrderAudit[]
  tags               SalesOrderTag[]
  timelines          SalesOrderTimeline[]
  references         SalesOrderReference[]
  attachments        SalesOrderAttachment[]
  approvals          SalesOrderApproval[]
  backorders         Backorder[]
  holds              OrderHold[]
  fulfillments       OrderFulfillment[]

  // Self-Relations for Split/Merge History
  splitAsOriginal    OrderSplitHistory[] @relation("OriginalOrderSplit")
  splitAsChild       OrderSplitHistory[] @relation("ChildOrderSplit")

  // Enterprise Invoices
  enterpriseInvoices EnterpriseInvoice[]

  // Payment Allocations
  paymentAllocations PaymentAllocation[]
  
  // Return Orders
  returnOrders       ReturnOrder[]

  @@unique([shopId, orderNumber])
  @@index([shopId, status])
  @@index([shopId, customerId])
}

model SalesOrderLine {
  id                 String             @id @default(cuid())
  orderId            String
  shopId             String
  productId          String
  variantId          String?
  
  sku                String?
  productName        String

  quantity           Decimal            @db.Decimal(12, 3)
  unitPrice          Decimal            @db.Decimal(15, 4)
  discount           Decimal            @db.Decimal(15, 4) @default(0)
  taxRate            Decimal            @db.Decimal(5, 2)  @default(0)
  lineTotal          Decimal            @db.Decimal(15, 4)

  order              SalesOrder         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Restrict)
  returnLines        ReturnLine[]

  @@index([shopId, productId])
  @@index([orderId])
}

model SalesOrderSnapshot {
  id                 String             @id @default(cuid())
  orderId            String
  shopId             String
  entityType         String             // e.g. "CUSTOMER", "PRODUCT", "TAX_RULE"
  entityId           String
  frozenData         Json               // The exact state of the entity when the order was placed
  createdAt          DateTime           @default(now())

  order              SalesOrder         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Restrict)

  @@index([orderId, entityType])
}

model SalesOrderStatusHistory {
  id                 String             @id @default(cuid())
  orderId            String
  shopId             String
  previousStatus     SalesOrderStatus?
  newStatus          SalesOrderStatus
  reason             String?            @db.Text
  actorId            String?
  createdAt          DateTime           @default(now())

  order              SalesOrder         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Restrict)

  @@index([orderId])
}

model SalesOrderAudit {
  id                 String             @id @default(cuid())
  orderId            String
  shopId             String
  field              String
  oldValue           Json?
  newValue           Json?
  actorId            String?
  ipAddress          String?
  deviceInfo         String?
  createdAt          DateTime           @default(now())

  order              SalesOrder         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Restrict)

  @@index([orderId])
}

model SalesOrderComment {
  id                 String             @id @default(cuid())
  orderId            String
  shopId             String
  content            String             @db.Text
  isInternal         Boolean            @default(true) // If true, customer doesn't see it
  authorId           String
  createdAt          DateTime           @default(now())

  order              SalesOrder         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Restrict)

  @@index([orderId])
}

model SalesOrderSequence {
  id                 String             @id @default(cuid())
  shopId             String
  prefix             String             @default("SO")
  yearMonth          String             // e.g. "202607"
  currentValue       Int                @default(0)
  
  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, prefix, yearMonth])
}

model SalesOrderTag {
  id                 String             @id @default(cuid())
  orderId            String
  shopId             String
  name               String

  order              SalesOrder         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Restrict)

  @@unique([orderId, name])
  @@index([shopId, name])
}

model SalesOrderTimeline {
  id                 String             @id @default(cuid())
  orderId            String
  shopId             String
  action             String             // Created, Updated, Confirmed, etc.
  actorId            String?
  metadata           Json?              // e.g. { reason: "Customer Request" }
  createdAt          DateTime           @default(now())

  order              SalesOrder         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Restrict)

  @@index([orderId, createdAt])
}

model SalesOrderReference {
  id                 String             @id @default(cuid())
  orderId            String
  shopId             String
  system             String             // e.g. "SHOPIFY", "AMAZON"
  externalId         String             
  externalUrl        String?

  order              SalesOrder         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Restrict)

  @@unique([orderId, system])
  @@index([shopId, system, externalId])
}

model SalesOrderAttachment {
  id                 String             @id @default(cuid())
  orderId            String
  shopId             String
  name               String
  fileUrl            String
  fileType           String
  uploadedBy         String?
  createdAt          DateTime           @default(now())

  order              SalesOrder         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Restrict)

  @@index([orderId])
}

model SalesOrderApproval {
  id                 String             @id @default(cuid())
  orderId            String
  shopId             String
  level              Int                @default(1)
  status             String             // PENDING, APPROVED, REJECTED
  approverId         String?            // Null if pending
  notes              String?            @db.Text
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  order              SalesOrder         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Restrict)

  @@index([orderId, status])
}

model OrderSplitHistory {
  id                 String             @id @default(cuid())
  shopId             String
  originalOrderId    String
  childOrderId       String
  reason             String?            @db.Text
  createdAt          DateTime           @default(now())

  originalOrder      SalesOrder         @relation("OriginalOrderSplit", fields: [originalOrderId], references: [id], onDelete: Cascade)
  childOrder         SalesOrder         @relation("ChildOrderSplit", fields: [childOrderId], references: [id], onDelete: Cascade)
  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Restrict)

  @@index([originalOrderId])
  @@index([childOrderId])
}

model Backorder {
  id                 String             @id @default(cuid())
  shopId             String
  orderId            String
  productId          String
  variantId          String?
  quantity           Decimal            @db.Decimal(12, 3)
  status             String             @default("PENDING") // PENDING, FULFILLED, CANCELLED
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  order              SalesOrder         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Restrict)

  @@index([shopId, productId])
  @@index([orderId, status])
}

model OrderHold {
  id                 String             @id @default(cuid())
  shopId             String
  orderId            String
  holdType           String             // CREDIT, FRAUD, MANUAL, INVENTORY
  reason             String             @db.Text
  status             String             @default("ACTIVE") // ACTIVE, RESOLVED
  resolverId         String?
  resolvedAt         DateTime?
  createdAt          DateTime           @default(now())

  order              SalesOrder         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Restrict)

  @@index([orderId, status])
  @@index([shopId, holdType, status])
}

model OrderFulfillment {
  id                 String             @id @default(cuid())
  shopId             String
  orderId            String
  warehouseId        String?            // If connected to Warehouse Domain
  status             String             @default("PENDING") // PENDING, PICKING, PACKED, SHIPPED, DELIVERED
  trackingNumber     String?
  carrier            String?
  dispatchedAt       DateTime?
  deliveredAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  order              SalesOrder         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([shopId, warehouseId, status])
}

// ==========================================
// PRICING DOMAIN
// ==========================================

model PriceList {
  id                 String             @id @default(cuid())
  shopId             String
  name               String
  type               String             @default("DEFAULT") // DEFAULT, STORE, WAREHOUSE, REGION, CUSTOMER, CUSTOMER_GROUP, CHANNEL
  currency           String             @default("USD")
  priority           Int                @default(0) // Higher number = higher priority
  isArchived         Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  versions           PriceListVersion[]

  @@unique([shopId, name])
  @@index([shopId, type, priority])
}

model PriceListVersion {
  id                 String             @id @default(cuid())
  priceListId        String
  shopId             String
  versionName        String
  status             String             @default("DRAFT") // DRAFT, PENDING, APPROVED, PUBLISHED, REJECTED, EXPIRED
  activationDate     DateTime?
  expiryDate         DateTime?
  authorId           String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  priceList          PriceList          @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  items              PriceListItem[]
  approvals          PriceApproval[]
  auditLogs          PriceAuditLog[]

  @@index([priceListId, status])
  @@index([shopId, activationDate, expiryDate])
}

model PriceListItem {
  id                 String             @id @default(cuid())
  versionId          String
  shopId             String
  productId          String
  variantId          String?
  basePrice          Decimal            @db.Decimal(15, 4)
  createdAt          DateTime           @default(now())

  version            PriceListVersion   @relation(fields: [versionId], references: [id], onDelete: Cascade)
  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  tiers              PricingTier[]

  @@unique([versionId, productId, variantId])
  @@index([shopId, productId])
}

model PricingTier {
  id                 String             @id @default(cuid())
  priceListItemId    String
  shopId             String
  minQuantity        Int
  maxQuantity        Int?               // Null means unlimited
  price              Decimal            @db.Decimal(15, 4)

  priceListItem      PriceListItem      @relation(fields: [priceListItemId], references: [id], onDelete: Cascade)
  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([priceListItemId, minQuantity])
}

model PricingRule {
  id                 String             @id @default(cuid())
  shopId             String
  name               String
  description        String?            @db.Text
  type               String             // PERCENTAGE, FLAT, BOGO, BUNDLE
  targetType         String             // CATEGORY, BRAND, PRODUCT, VARIANT, CART, CUSTOMER_GROUP
  targetId           String?            // Null if Cart level
  value              Decimal            @db.Decimal(15, 4)
  isStackable        Boolean            @default(false)
  priority           Int                @default(0)
  conditions         Json?              // e.g. { minOrderValue: 100 }
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, type, isActive])
}

model Coupon {
  id                 String             @id @default(cuid())
  shopId             String
  code               String             
  pricingRuleId      String?
  usageLimit         Int?
  usageCount         Int                @default(0)
  perCustomerLimit   Int?
  activationDate     DateTime?
  expiryDate         DateTime?
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  usages             CouponUsage[]

  @@unique([shopId, code])
  @@index([shopId, isActive, expiryDate])
}

model CouponUsage {
  id                 String             @id @default(cuid())
  couponId           String
  shopId             String
  customerId         String
  orderId            String
  usedAt             DateTime           @default(now())

  coupon             Coupon             @relation(fields: [couponId], references: [id], onDelete: Cascade)
  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([couponId, customerId])
}

model Promotion {
  id                 String             @id @default(cuid())
  shopId             String
  name               String
  campaignType       String             // FLASH_SALE, FESTIVAL, CLEARANCE
  status             String             @default("DRAFT")
  activationDate     DateTime?
  expiryDate         DateTime?
  pricingRuleIds     Json               // Array of rule IDs
  priority           Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, status, activationDate])
}

model PriceApproval {
  id                 String             @id @default(cuid())
  versionId          String
  shopId             String
  level              Int                @default(1)
  status             String             // PENDING, APPROVED, REJECTED
  approverId         String?            
  notes              String?            @db.Text
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  version            PriceListVersion   @relation(fields: [versionId], references: [id], onDelete: Cascade)
  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([versionId, status])
}

model PriceAuditLog {
  id                 String             @id @default(cuid())
  versionId          String
  shopId             String
  action             String             // CREATED, UPDATED, APPROVED, REJECTED, PUBLISHED, ROLLED_BACK
  actorId            String?
  oldValue           Json?
  newValue           Json?
  reason             String?            @db.Text
  createdAt          DateTime           @default(now())

  version            PriceListVersion   @relation(fields: [versionId], references: [id], onDelete: Cascade)
  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([versionId, createdAt])
}

// ==========================================
// ENTERPRISE INVOICE DOMAIN
// ==========================================

model NumberSequence {
  id                 String             @id @default(cuid())
  shopId             String
  entityType         String             // INVOICE, CREDIT_NOTE, DEBIT_NOTE
  prefix             String             // e.g. INV/2026/
  lastNumber         Int                @default(0)
  updatedAt          DateTime           @updatedAt

  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, entityType, prefix])
}

model EnterpriseInvoice {
  id                 String             @id @default(cuid())
  shopId             String
  orderId            String?            // Optional if generated independently
  customerId         String?
  invoiceNumber      String             // Immutable after GENERATED
  type               String             // TAX_INVOICE, PROFORMA, QUOTATION
  status             String             @default("DRAFT") // DRAFT, PENDING, ISSUED, PAID, PARTIAL_PAID, CANCELLED, VOID
  subTotal           Decimal            @db.Decimal(15, 4)
  taxTotal           Decimal            @db.Decimal(15, 4)
  discountTotal      Decimal            @db.Decimal(15, 4)
  grandTotal         Decimal            @db.Decimal(15, 4)
  currency           String             @default("USD")
  issueDate          DateTime?
  dueDate            DateTime?
  pdfUrl             String?            // Snapshot URL
  metadata           Json?
  notes              String?            @db.Text
  terms              String?            @db.Text
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  salesOrder         SalesOrder?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  versions           EnterpriseInvoiceVersion[]
  lines              EnterpriseInvoiceLine[]
  taxes              EnterpriseInvoiceTax[]
  creditNotes        CreditNote[]
  debitNotes         DebitNote[]
  paymentAllocations PaymentAllocation[]
  returnOrders       ReturnOrder[]

  @@unique([shopId, invoiceNumber])
  @@index([shopId, status])
  @@index([orderId])
  @@index([customerId])
}

model EnterpriseInvoiceVersion {
  id                 String             @id @default(cuid())
  invoiceId          String
  shopId             String
  versionNumber      Int
  snapshotData       Json               // Complete JSON serialization of the invoice state
  authorId           String?
  reason             String?            @db.Text
  createdAt          DateTime           @default(now())

  invoice            EnterpriseInvoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([invoiceId, versionNumber])
}

model EnterpriseInvoiceLine {
  id                 String             @id @default(cuid())
  invoiceId          String
  shopId             String
  productId          String?
  variantId          String?
  description        String             // Frozen item name
  hsnSac             String?
  quantity           Int
  unitPrice          Decimal            @db.Decimal(15, 4)
  discount           Decimal            @db.Decimal(15, 4)
  taxAmount          Decimal            @db.Decimal(15, 4)
  lineTotal          Decimal            @db.Decimal(15, 4)

  invoice            EnterpriseInvoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  returnLines        ReturnLine[]

  @@index([invoiceId])
}

model EnterpriseInvoiceTax {
  id                 String             @id @default(cuid())
  invoiceId          String
  shopId             String
  taxType            String             // CGST, SGST, IGST, CESS
  taxRate            Decimal            @db.Decimal(5, 2)
  taxableAmount      Decimal            @db.Decimal(15, 4)
  taxAmount          Decimal            @db.Decimal(15, 4)

  invoice            EnterpriseInvoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model CreditNote {
  id                 String             @id @default(cuid())
  shopId             String
  invoiceId          String
  noteNumber         String
  amount             Decimal            @db.Decimal(15, 4)
  reason             String             @db.Text
  status             String             @default("ISSUED") // ISSUED, VOID
  createdAt          DateTime           @default(now())

  invoice            EnterpriseInvoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, noteNumber])
  @@index([invoiceId])
}

model DebitNote {
  id                 String             @id @default(cuid())
  shopId             String
  invoiceId          String
  noteNumber         String
  amount             Decimal            @db.Decimal(15, 4)
  reason             String             @db.Text
  status             String             @default("ISSUED") // ISSUED, VOID
  createdAt          DateTime           @default(now())

  invoice            EnterpriseInvoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, noteNumber])
  @@index([invoiceId])
}

model EnterpriseInvoiceAuditLog {
  id                 String             @id @default(cuid())
  invoiceId          String
  shopId             String
  action             String             // PRINTED, DOWNLOADED, EMAILED, VOIDED, STATUS_CHANGED
  actorId            String?
  metadata           Json?
  createdAt          DateTime           @default(now())

  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([invoiceId, createdAt])
}

// ==========================================
// PAYMENT DOMAIN
// ==========================================

model PaymentTransaction {
  id                 String             @id @default(cuid())
  shopId             String
  idempotencyKey     String             // Guards against duplicate charges
  amount             Decimal            @db.Decimal(15, 4)
  currency           String             @default("USD")
  method             String             // CASH, UPI, CC, DC, WALLET, BANK_TRANSFER
  status             String             @default("INITIATED") // INITIATED, PENDING, AUTHORIZED, CAPTURED, FAILED, REFUNDED
  reference          String?            // External gateway reference (e.g. pay_XXXX)
  metadata           Json?              // Gateway response dump
  actorId            String?            // Cashier or Customer ID
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  allocations        PaymentAllocation[]
  refunds            PaymentRefund[]
  ledgerEntries      PaymentLedger[]

  @@unique([shopId, idempotencyKey])
  @@index([shopId, status])
  @@index([reference])
}

model PaymentAllocation {
  id                 String             @id @default(cuid())
  shopId             String
  transactionId      String
  invoiceId          String?
  orderId            String?
  amount             Decimal            @db.Decimal(15, 4)
  createdAt          DateTime           @default(now())

  transaction        PaymentTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  invoice            EnterpriseInvoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  order              SalesOrder?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([invoiceId])
  @@index([orderId])
}

model PaymentRefund {
  id                 String             @id @default(cuid())
  shopId             String
  transactionId      String
  amount             Decimal            @db.Decimal(15, 4)
  reason             String             @db.Text
  status             String             @default("INITIATED") // INITIATED, PROCESSING, COMPLETED, FAILED
  reference          String?            // Gateway refund ID
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  transaction        PaymentTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  ledgerEntries      PaymentLedger[]

  @@index([transactionId])
}

model PaymentLedger {
  id                 String             @id @default(cuid())
  shopId             String
  transactionId      String?
  refundId           String?
  type               String             // DEBIT, CREDIT
  amount             Decimal            @db.Decimal(15, 4)
  description        String
  balanceAfter       Decimal?           @db.Decimal(15, 4) // Materialized view of account balance (optional)
  createdAt          DateTime           @default(now())

  transaction        PaymentTransaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  refund             PaymentRefund?      @relation(fields: [refundId], references: [id], onDelete: Cascade)
  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, createdAt])
  @@index([transactionId])
}

model CashDrawerSession {
  id                 String             @id @default(cuid())
  shopId             String
  cashierId          String
  openingBalance     Decimal            @db.Decimal(15, 4)
  closingBalance     Decimal?           @db.Decimal(15, 4)
  expectedBalance    Decimal?           @db.Decimal(15, 4)
  discrepancy        Decimal?           @db.Decimal(15, 4)
  status             String             @default("OPEN") // OPEN, CLOSED, AUDITED
  openedAt           DateTime           @default(now())
  closedAt           DateTime?

  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, status])
  @@index([cashierId, status])
}

// ==========================================
// RETURNS & EXCHANGE DOMAIN
// ==========================================

model ReturnOrder {
  id                 String             @id @default(cuid())
  shopId             String
  returnNumber       String             // e.g. RET/26/0001
  invoiceId          String?            // Link to EnterpriseInvoice
  orderId            String?            // Link to SalesOrder
  customerId         String?
  type               String             // FULL_RETURN, PARTIAL_RETURN, EXCHANGE
  status             String             @default("REQUESTED") // REQUESTED, APPROVED, RECEIVED, INSPECTED, COMPLETED, REJECTED, REFUNDED
  refundAmount       Decimal            @default(0) @db.Decimal(15, 4)
  refundStatus       String             @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  reason             String?            @db.Text
  metadata           Json?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  invoice            EnterpriseInvoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  order              SalesOrder?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  lines              ReturnLine[]
  timelines          ReturnTimeline[]
  inspections        ReturnInspection[]
  exchanges          ProductExchange[]

  @@unique([shopId, returnNumber])
  @@index([shopId, status])
  @@index([invoiceId])
  @@index([orderId])
}

model ReturnLine {
  id                 String             @id @default(cuid())
  returnOrderId      String
  shopId             String
  invoiceLineId      String?
  orderLineId        String?
  productId          String
  variantId          String?
  quantity           Int
  returnReason       String
  isExchanged        Boolean            @default(false)
  
  returnOrder        ReturnOrder        @relation(fields: [returnOrderId], references: [id], onDelete: Cascade)
  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  invoiceLine        EnterpriseInvoiceLine? @relation(fields: [invoiceLineId], references: [id], onDelete: SetNull)
  orderLine          SalesOrderLine?    @relation(fields: [orderLineId], references: [id], onDelete: SetNull)

  @@index([returnOrderId])
}

model ReturnTimeline {
  id                 String             @id @default(cuid())
  returnOrderId      String
  shopId             String
  status             String
  notes              String?            @db.Text
  actorId            String?
  createdAt          DateTime           @default(now())

  returnOrder        ReturnOrder        @relation(fields: [returnOrderId], references: [id], onDelete: Cascade)
  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([returnOrderId, createdAt])
}

model ReturnInspection {
  id                 String             @id @default(cuid())
  returnOrderId      String
  shopId             String
  inspectorId        String
  grade              String             // PASS, FAIL, REPAIR
  disposition        String             // RESTOCK, QUARANTINE, DISPOSE
  notes              String?            @db.Text
  imageUrls          Json?              // Array of URLs
  createdAt          DateTime           @default(now())

  returnOrder        ReturnOrder        @relation(fields: [returnOrderId], references: [id], onDelete: Cascade)
  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([returnOrderId])
}

model ProductExchange {
  id                 String             @id @default(cuid())
  returnOrderId      String
  shopId             String
  originalProductId  String
  originalVariantId  String?
  newProductId       String
  newVariantId       String?
  priceDifference    Decimal            @default(0) @db.Decimal(15, 4) // Positive means customer owes, negative means store owes
  status             String             @default("PENDING") // PENDING, FULFILLED
  createdAt          DateTime           @default(now())

  returnOrder        ReturnOrder        @relation(fields: [returnOrderId], references: [id], onDelete: Cascade)
  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([returnOrderId])
}

// ==========================================
// ENTERPRISE SALES ANALYTICS DOMAIN
// ==========================================

model DailySalesAggregation {
  id                 String             @id @default(cuid())
  shopId             String
  date               DateTime           @db.Date
  
  // Revenue Metrics
  grossRevenue       Decimal            @default(0) @db.Decimal(15, 4)
  netRevenue         Decimal            @default(0) @db.Decimal(15, 4)
  totalTax           Decimal            @default(0) @db.Decimal(15, 4)
  totalDiscounts     Decimal            @default(0) @db.Decimal(15, 4)
  totalRefunds       Decimal            @default(0) @db.Decimal(15, 4)
  
  // Volume Metrics
  ordersCount        Int                @default(0)
  itemsSold          Int                @default(0)
  returnsCount       Int                @default(0)

  // Profit Metrics
  totalCogs          Decimal            @default(0) @db.Decimal(15, 4) // Cost of Goods Sold
  grossProfit        Decimal            @default(0) @db.Decimal(15, 4)

  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, date])
  @@index([shopId, date])
}

model ProductSalesAggregation {
  id                 String             @id @default(cuid())
  shopId             String
  productId          String
  month              DateTime           @db.Date // Store as 1st of every month for aggregation

  unitsSold          Int                @default(0)
  unitsReturned      Int                @default(0)
  grossRevenue       Decimal            @default(0) @db.Decimal(15, 4)
  netRevenue         Decimal            @default(0) @db.Decimal(15, 4)
  totalCogs          Decimal            @default(0) @db.Decimal(15, 4)
  
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product            Product            @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([shopId, productId, month])
  @@index([shopId, month])
}

model AnalyticsExportJob {
  id                 String             @id @default(cuid())
  shopId             String
  type               String             // CSV, EXCEL, PDF
  reportName         String
  status             String             @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  fileUrl            String?
  errorMessage       String?            @db.Text
  filters            Json?              // Store the requested filters
  requestedById      String
  createdAt          DateTime           @default(now())
  completedAt        DateTime?

  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, status])
}

model PurchaseEventAudit {
  id                String   @id @default(cuid())
  shopId            String
  outboxEventId     String
  eventType         String
  aggregateId       String?
  status            String   // DELIVERED, REPLAYED, FAILED
  actorId           String?
  metadata          Json?
  
  createdAt         DateTime @default(now())

  @@index([shopId, outboxEventId])
  @@index([shopId, eventType])
  @@index([aggregateId])
}

model PurchaseEventReplay {
  id                String   @id @default(cuid())
  shopId            String
  targetEventId     String?
  targetAggregateId String?
  requestedById     String
  status            String   // PENDING, COMPLETED, FAILED
  resultSummary     String?  @db.Text
  
  createdAt         DateTime @default(now())
  completedAt       DateTime?

  @@index([shopId, status])
}

model PurchaseEventDelivery {
  id                String   @id @default(cuid())
  shopId            String
  outboxEventId     String
  consumerName      String   // e.g., 'INVENTORY_SYNC', 'ANALYTICS_UPDATE'
  status            String   // SUCCESS, FAILED
  latencyMs         Int?
  errorMessage      String?  @db.Text
  
  createdAt         DateTime @default(now())

  @@index([shopId, outboxEventId])
  @@index([consumerName, status])
}

model PurchaseDeadLetter {
  id                String   @id @default(cuid())
  shopId            String
  outboxEventId     String
  eventType         String
  payload           Json
  failureReason     String   @db.Text
  lastAttemptAt     DateTime
  retryCount        Int      @default(0)
  status            String   @default("ACTIVE") // ACTIVE, RESOLVED, DISCARDED
  
  createdAt         DateTime @default(now())
  resolvedAt        DateTime?

  @@index([shopId, status])
}

model PurchaseWebhookDelivery {
  id                String   @id @default(cuid())
  shopId            String
  outboxEventId     String
  endpointUrl       String
  httpStatus        Int?
  requestPayload    Json
  responseBody      String?  @db.Text
  errorMessage      String?  @db.Text
  latencyMs         Int?
  
  createdAt         DateTime @default(now())

  @@index([shopId, outboxEventId])
  @@index([shopId, httpStatus])
}

model PurchaseConsumerState {
  id                String   @id @default(cuid())
  shopId            String
  consumerName      String
  lastProcessedId   String?
  lastProcessedAt   DateTime?
  
  updatedAt         DateTime @updatedAt

  @@unique([shopId, consumerName])
}

model PurchaseEventStatistics {
  id                String   @id @default(cuid())
  shopId            String
  date              DateTime @db.Date
  
  totalPublished    Int      @default(0)
  totalDelivered    Int      @default(0)
  totalFailed       Int      @default(0)
  totalDeadLettered Int      @default(0)
  
  updatedAt         DateTime @updatedAt

  @@unique([shopId, date])
}

