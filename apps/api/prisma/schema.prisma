enum WorkflowStatus {
  ACTIVE
  COMPLETED
  REJECTED
  CANCELLED
  ESCALATED
}

enum WorkflowTaskStatus {
  PENDING
  APPROVED
  REJECTED
  DELEGATED
  ESCALATED
  CANCELLED
}

model WorkflowDefinition {
  id                String   @id @default(cuid())
  shopId            String
  name              String
  documentType      String   // PURCHASE_ORDER, VENDOR_BILL, GRN, PURCHASE_RETURN, SUPPLIER_CREDIT
  description       String?  @db.Text
  isActive          Boolean  @default(true)
  version           Int      @default(1)
  
  // JSON array of budget/threshold conditions to determine if this workflow applies
  conditions        Json?    
  
  steps             WorkflowStep[]
  instances         WorkflowInstance[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@unique([shopId, name, version])
  @@index([shopId, documentType])
}

model WorkflowStep {
  id                   String   @id @default(cuid())
  workflowDefinitionId String
  stepOrder            Int
  name                 String
  approverRole         String?  // The role required to approve (e.g. FINANCE_MANAGER)
  approverId           String?  // Specific user ID
  departmentId         String?  // Department required
  isParallel           Boolean  @default(false)
  
  // Conditions evaluated to see if this specific step is required (e.g. amount > 5000)
  conditions           Json?
  
  // SLA configuration
  slaMinutes           Int?     // Allowed time before escalation
  escalationRoleId     String?  // Who to escalate to
  
  workflowDefinition   WorkflowDefinition @relation(fields: [workflowDefinitionId], references: [id], onDelete: Cascade)
  
  @@index([workflowDefinitionId])
}

model WorkflowInstance {
  id                   String   @id @default(cuid())
  shopId               String
  workflowDefinitionId String
  
  // Bound Documents
  purchaseOrderId      String?
  goodsReceiptId       String?
  vendorBillId         String?
  purchaseReturnId     String?
  supplierCreditId     String?
  
  status               WorkflowStatus @default(ACTIVE)
  currentStepOrder     Int            @default(1)
  
  startedBy            String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  workflowDefinition   WorkflowDefinition @relation(fields: [workflowDefinitionId], references: [id], onDelete: Restrict)
  purchaseOrder        PurchaseOrder?     @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  goodsReceipt         GoodsReceipt?      @relation(fields: [goodsReceiptId], references: [id], onDelete: SetNull)
  vendorBill           VendorBill?        @relation(fields: [vendorBillId], references: [id], onDelete: SetNull)
  purchaseReturn       PurchaseReturn?    @relation(fields: [purchaseReturnId], references: [id], onDelete: SetNull)
  supplierCredit       SupplierCreditNote? @relation(fields: [supplierCreditId], references: [id], onDelete: SetNull)

  tasks                WorkflowTask[]
  timeline             WorkflowTimeline[]

  @@index([shopId, status])
  @@index([purchaseOrderId])
  @@index([vendorBillId])
}

model WorkflowTask {
  id                   String   @id @default(cuid())
  workflowInstanceId   String
  shopId               String
  stepOrder            Int
  
  assignedRoleId       String?
  assignedUserId       String?
  departmentId         String?
  
  status               WorkflowTaskStatus @default(PENDING)
  comments             String?            @db.Text
  digitalSignature     String?
  
  delegatedToUserId    String?
  escalatedToRoleId    String?
  
  deadline             DateTime?
  completedAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  workflowInstance     WorkflowInstance   @relation(fields: [workflowInstanceId], references: [id], onDelete: Cascade)

  @@index([workflowInstanceId])
  @@index([assignedUserId])
  @@index([shopId, status])
}

model WorkflowDelegation {
  id                   String   @id @default(cuid())
  shopId               String
  delegatorUserId      String
  delegateUserId       String
  startDate            DateTime
  endDate              DateTime
  isActive             Boolean  @default(true)
  notes                String?  @db.Text
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  
  @@index([shopId, delegatorUserId])
}

model WorkflowTimeline {
  id                   String   @id @default(cuid())
  workflowInstanceId   String
  shopId               String
  actorId              String?
  action               String   // e.g. SUBMITTED, APPROVED, DELEGATED, ESCALATED
  notes                String?  @db.Text
  metadata             Json?
  
  createdAt            DateTime @default(now())

  workflowInstance     WorkflowInstance @relation(fields: [workflowInstanceId], references: [id], onDelete: Cascade)

  @@index([workflowInstanceId])
  @@index([shopId, action])
}

model PurchaseAnalyticsSnapshot {
