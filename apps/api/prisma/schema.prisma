model PurchaseAnalyticsJob {
  id                   String   @id @default(cuid())
  shopId               String
  jobType              String   // AGGREGATE_DAILY, CALCULATE_VENDOR_SCORE
  status               String   // PENDING, COMPLETED, FAILED
