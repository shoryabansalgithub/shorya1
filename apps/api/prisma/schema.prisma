  POSTED
  CANCELLED
}

enum CountType {
  FULL_COUNT
  CYCLE_COUNT
  SPOT_CHECK
  BIN_COUNT
  ZONE_COUNT
}

enum AdjustmentStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  POSTED
  FAILED
}

enum ReservationStatus {
  CREATED
  PENDING
  PARTIALLY_RESERVED
