  APPROVED
  REJECTED
}

enum GstRate {
  ZERO
  FIVE
  TWELVE
  EIGHTEEN
  TWENTYEIGHT
}

enum NotificationType {
  LOW_STOCK
  UDHAR_OVERDUE
  SHIFT_NOT_CLOSED
  PAYMENT_RECEIVED
  LARGE_DISCOUNT
  SUSPICIOUS_ACTIVITY
