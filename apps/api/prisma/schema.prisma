  AUTO_RELEASED
}

enum ReservationSource {
  SALES_ORDER
  POS
  WEBSITE
  MOBILE_APP
  MARKETPLACE
  PURCHASE_RETURN
  MANUFACTURING
  WAREHOUSE_TRANSFER
  API
  SYSTEM
}

enum AllocationStatus {
  PENDING
  LOCKED
  RELEASED
  FULFILLED
}

enum StockMovementType {
  PURCHASE
  SALE
  SALE_RETURN
  PURCHASE_RETURN
  TRANSFER_OUT
  TRANSFER_IN
  MANUFACTURING_INPUT
  MANUFACTURING_OUTPUT
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  OPENING_BALANCE
  CLOSING_BALANCE
  RESERVATION
  RESERVATION_RELEASE
  DAMAGE
  LOSS
  EXPIRY
  QUARANTINE
  CONSUMPTION
  CORRECTION
  IMPORT
  EXPORT
  SYSTEM_CORRECTION
}

model Shop {
  id        String     @id @default(cuid())
  name      String
  address   String?
  city      String?
  state     String?
  pincode   String?
  phone     String?
  email     String?
  logoUrl   String?
  status    ShopStatus @default(ACTIVE)
  ownerId   String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  isDeleted Boolean    @default(false)
  deletedAt DateTime?

  owner    User          @relation("ShopOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  settings ShopSettings?

  users                User[]
  categories           Category[]
  products             Product[]
  productBatches       ProductBatch[]
  suppliers            Supplier[]
  customers            Customer[]
  shifts               Shift[]
  invoices             Invoice[]
  udharTransactions    UdharTransaction[]
  inventoryLogs        InventoryLog[]
  auditLogs            AuditLog[]
  purchaseOrders       PurchaseOrder[]
  stockTransfersIn     StockTransfer[]       @relation("TransferDestinationShop")
  stockTransfersOut    StockTransfer[]       @relation("TransferSourceShop")
  notifications        Notification[]
  ledgerTransactions   LedgerTransaction[]
  inventoryDriftLogs   InventoryDriftLog[]
  invitations          Invitation[]
  brands               Brand[]
  manufacturers        Manufacturer[]
  variantAttributes    VariantAttribute[]
  productVariants      ProductVariant[]
  productBarcodes      ProductBarcode[]
  productAttributes    ProductAttribute[]
  productTags          ProductTag[]
  productImages        ProductImage[]
  productPriceTiers    ProductPriceTier[]
  productRelationships ProductRelationship[]

  productIdentities ProductIdentity[]
  variantIdentities VariantIdentity[]
  packageIdentities PackageIdentity[]
  barcodes          Barcode[]
  barcodeHistories  BarcodeHistory[]
  barcodeTemplates  BarcodeTemplate[]
  barcodePrintJobs  BarcodePrintJob[]
  qrCodes           QrCode[]
  mediaAssets       MediaAsset[]
  mediaVersions     MediaVersion[]
  mediaTags         MediaTag[]
  mediaAudits       MediaAudit[]
  mediaStorages     MediaStorage[]
  mediaThumbnails   MediaThumbnail[]
  mediaReferences   MediaReference[]
  searchHistories    SearchHistory[]
  savedSearches      SavedSearch[]
  searchAnalytics    SearchAnalytics[]
  searchSynonyms     SearchSynonym[]
  searchBoosts       SearchBoost[]
  searchClicks       SearchClick[]
  searchIndexStatuses SearchIndexStatus[]
  validationRules    ValidationRule[]
  duplicateCandidates DuplicateCandidate[]
  productQualityScores ProductQualityScore[]
  productValidationIssues ProductValidationIssue[]
  importJobs         ImportJob[]
  exportJobs         ExportJob[]
  importMappings     ImportMapping[]
  rollbackRecords    RollbackRecord[]
  productEventLogs   ProductEventLog[]
  outboxEvents       OutboxEvent[]
  webhookEndpoints   WebhookEndpoint[]
  deadLetterEvents   DeadLetterEvent[]
  inventoryItems     InventoryItem[]
  inventoryAdjustments InventoryAdjustment[]
  inventoryMovements InventoryMovement[]
  inventorySnapshots InventorySnapshot[]
  inventoryThresholds InventoryThreshold[]
  inventoryAlerts    InventoryAlert[]
  warehouses         Warehouse[]
  locations          Location[]
  locationCapacityLogs LocationCapacityLog[]
  stockLedgerEntries StockLedgerEntry[]
  stockSnapshots     StockSnapshot[]
  stockReservations  StockReservation[]
  reservationItems   ReservationItem[]
  reservationAllocations ReservationAllocation[]
  stockCountSessions StockCountSession[]
  stockCountItems    StockCountItem[]
  adjustmentRequests AdjustmentRequest[]
  batches            Batch[]
  batchStocks        BatchStock[]
  batchRecalls       BatchRecall[]
  inventoryKpis      InventoryKpi[]
  inventoryClassifications InventoryClassification[]
  inventoryRecommendations InventoryRecommendation[]
  inventoryEventLogs       InventoryEventLog[]

  // Sales Domain
  salesOrders              SalesOrder[]
  salesOrderLines          SalesOrderLine[]
  salesOrderSnapshots      SalesOrderSnapshot[]
  salesOrderStatusHistories SalesOrderStatusHistory[]
  salesOrderAudits         SalesOrderAudit[]
  salesOrderComments       SalesOrderComment[]
  salesOrderSequences      SalesOrderSequence[]
  salesOrderTags           SalesOrderTag[]
  salesOrderTimelines      SalesOrderTimeline[]
  salesOrderReferences     SalesOrderReference[]
  salesOrderAttachments    SalesOrderAttachment[]
  salesOrderApprovals      SalesOrderApproval[]
  salesOrderSplits         OrderSplitHistory[]
  salesOrderBackorders     Backorder[]
  salesOrderHolds          OrderHold[]
  salesOrderFulfillments   OrderFulfillment[]

  // Pricing Domain Relations
  priceLists               PriceList[]
  priceListVersions        PriceListVersion[]
  priceListItems           PriceListItem[]
  pricingTiers             PricingTier[]
  pricingRules             PricingRule[]
  coupons                  Coupon[]
  couponUsages             CouponUsage[]
  promotions               Promotion[]
  priceApprovals           PriceApproval[]
  priceAuditLogs           PriceAuditLog[]
  // Invoice Domain Relations
  numberSequences          NumberSequence[]
  enterpriseInvoices       EnterpriseInvoice[]
  enterpriseInvoiceVers    EnterpriseInvoiceVersion[]
  enterpriseInvoiceLines   EnterpriseInvoiceLine[]
  enterpriseInvoiceTaxes   EnterpriseInvoiceTax[]
  creditNotes              CreditNote[]
  debitNotes               DebitNote[]
  enterpriseInvoiceAudits  EnterpriseInvoiceAuditLog[]

  // Payment Domain Relations
  paymentTransactions      PaymentTransaction[]
  paymentAllocations       PaymentAllocation[]
  paymentRefunds           PaymentRefund[]
  paymentLedgers           PaymentLedger[]
  cashDrawerSessions       CashDrawerSession[]

  // Returns Domain Relations
  returnOrders             ReturnOrder[]
  returnLines              ReturnLine[]
  returnTimelines          ReturnTimeline[]
  returnInspections        ReturnInspection[]
  productExchanges         ProductExchange[]

  // Analytics Domain Relations
  dailySalesAggregations   DailySalesAggregation[]
  productSalesAggregations ProductSalesAggregation[]
  analyticsExportJobs      AnalyticsExportJob[]
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  googleId       String?   @unique
  password       String?
  name           String
  phone          String?
  role           Role
  isActive       Boolean   @default(true)
  shopId         String
  isLocked       Boolean   @default(false)
  lockedUntil    DateTime?
  lastLoginAt    DateTime?
  lastLoginIp    String?
  failedAttempts Int       @default(0)
  tokenVersion   Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  isDeleted      Boolean   @default(false)
  deletedAt      DateTime?

  shop              Shop               @relation(fields: [shopId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ownedShop         Shop?              @relation("ShopOwner")
  refreshTokens     RefreshToken[]
  loginAttempts     LoginAttempt[]
  shiftsOpened      Shift[]            @relation("ShiftOpenedBy")
  shiftsClosed      Shift[]            @relation("ShiftClosedBy")
  invoices          Invoice[]          @relation("InvoiceCashier")
  barcodeChanges    BarcodeHistory[]
  printJobs         BarcodePrintJob[]
  udharTransactions UdharTransaction[] @relation("UdharRecordedBy")
  inventoryLogs     InventoryLog[]     @relation("InventoryRecordedBy")
  mediaAudits       MediaAudit[]
  auditLogs         AuditLog[]         @relation("AuditUser")
  searchHistories   SearchHistory[]
  savedSearches     SavedSearch[]
  searchClicks      SearchClick[]

  @@index([shopId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Invitation {
  id        String   @id @default(cuid())
  email     String
  role      Role
  shopId    String
  token     String   @unique
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([email])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  userId    String
  ipAddress String
  userAgent String?
  success   Boolean
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
  @@index([userId])
}

model Category {
  id           String    @id @default(cuid())
  name         String
  slug         String    @default("")
  shopId       String
  parentId     String?
  path         String    @default("/")
  depth        Int       @default(0)
  sortOrder    Int       @default(0)
  isActive     Boolean   @default(true)
  imageUrl     String?
  productCount Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?

  shop          Shop       @relation(fields: [shopId], references: [id], onDelete: Restrict)
  parent        Category?  @relation("SubCategories", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subCategories Category[] @relation("SubCategories")
  products      Product[]

  @@unique([shopId, name, deletedAt])
  @@index([shopId])
  @@index([parentId])
  @@index([shopId, path])
  @@index([shopId, isActive])
}

model Product {
  id          String        @id @default(cuid())
  name        String
  slug        String        @default("")
  sku         String
  barcode     String?
  description String?       @db.Text
  type        ProductType   @default(SIMPLE)
  status      ProductStatus @default(ACTIVE)

  costPrice       Decimal  @db.Decimal(10, 2)
  sellingPrice    Decimal  @db.Decimal(10, 2)
  mrp             Decimal  @db.Decimal(10, 2)
  wholesalePrice  Decimal  @db.Decimal(10, 2)
  minSellingPrice Decimal? @db.Decimal(10, 2)
  maxDiscountPct  Decimal? @db.Decimal(5, 2)

  gstRate  GstRate @default(EIGHTEEN)
  cessRate Decimal @default(0) @db.Decimal(5, 2)
  hsnCode  String?

  currentPublishedRevId String? @unique
  currentDraftRevId     String? @unique

  categoryId     String?
  shopId         String
  supplierId     String?
  brandId        String?
  manufacturerId String?

  currentStock Decimal @default(0) @db.Decimal(10, 3)
  stockVersion Int     @default(0)
  reorderPoint Decimal @default(10) @db.Decimal(10, 3)
  reorderQty   Decimal @default(50) @db.Decimal(10, 3)

  totalUnitsSold Decimal   @default(0) @db.Decimal(10, 3)
  totalRevenue   Decimal   @default(0) @db.Decimal(12, 2)
  lastSoldAt     DateTime?
  analyticsClass String?

  unit             ProductUnit
  hasExpiry        Boolean     @default(false)
  defaultShelfLife Int?
  isActive         Boolean     @default(true)
  imageUrl         String?
  aliases          String?     @db.Text
  searchKeywords   String?     @db.Text

  version    Int       @default(1)
  createdBy  String?
  updatedBy  String?
  approvedBy String?
  approvedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  shop         Shop          @relation(fields: [shopId], references: [id], onDelete: Restrict)
  category     Category?     @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  supplier     Supplier?     @relation(fields: [supplierId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  brand        Brand?        @relation(fields: [brandId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  manufacturer Manufacturer? @relation(fields: [manufacturerId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  batches            ProductBatch[]
  invoiceItems       InvoiceItem[]
  inventoryLogs      InventoryLog[]
  purchaseOrderItems PurchaseOrderItem[]
  stockTransferItems StockTransferItem[]
  inventoryDriftLogs InventoryDriftLog[]

  revisions       ProductRevision[]
  branches        RevisionBranch[]
  variants        ProductVariant[]
  barcodes        ProductBarcode[]
  images          ProductImage[]
  attributes      ProductAttribute[]
  tags            ProductTag[]
  priceTiers      ProductPriceTier[]
  reservationItems ReservationItem[]
  enterpriseBatches Batch[] @relation("EnterpriseBatches")
  relationsSource ProductRelationship[] @relation("RelationSource")
  relationsTarget ProductRelationship[] @relation("RelationTarget")
  skuHistory      SkuHistory[]
  inventoryKpis   InventoryKpi[]
  inventoryClassifications InventoryClassification[]
  inventoryRecommendations InventoryRecommendation[]

  productIdentity   ProductIdentity?
  globalBarcodes    Barcode[]
  packageIdentities PackageIdentity[]
  qrCodes           QrCode[]
  mediaReferences   MediaReference[]
  qualityScore      ProductQualityScore?
  validationIssues  ProductValidationIssue[]
  duplicateSources  DuplicateCandidate[] @relation("DuplicateSource")
  duplicateTargets  DuplicateCandidate[] @relation("DuplicateTarget")
  inventoryItems    InventoryItem[]
  productSalesAggregations ProductSalesAggregation[]

  @@unique([shopId, sku, deletedAt])
  @@index([shopId, status])
  @@index([shopId, categoryId])
  @@index([shopId, brandId])
  @@index([shopId, type])
  @@fulltext([name, aliases, searchKeywords])
}

model ProductBatch {
  id           String    @id @default(cuid())
  productId    String
  shopId       String
  batchNumber  String
  expiryDate   DateTime?
  costPrice    Decimal   @db.Decimal(10, 2)
  mrp          Decimal   @db.Decimal(10, 2)
  sellingPrice Decimal   @db.Decimal(10, 2)
  initialStock Decimal   @db.Decimal(10, 3)
  currentStock Decimal   @db.Decimal(10, 3)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?

  product Product @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  shop    Shop    @relation(fields: [shopId], references: [id], onDelete: Restrict)

  @@index([productId])
  @@index([shopId, expiryDate])
}

model Supplier {
  id        String    @id @default(cuid())
  name      String
  phone     String
  email     String?
  gstin     String?
  address   String?
  city      String?
  state     String?
  shopId    String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  shop           Shop            @relation(fields: [shopId], references: [id], onDelete: Restrict)
  products       Product[]
  purchaseOrders PurchaseOrder[]
  goodsReceipts  GoodsReceipt[]
  vendorBills    VendorBill[]
  purchaseReturns PurchaseReturn[]
  supplierCredits SupplierCreditNote[]

  @@unique([shopId, phone, deletedAt])
  @@index([shopId])
}

model Customer {
  id                 String    @id @default(cuid())
  name               String
  phone              String
  email              String?
  address            String?
  city               String?
  state              String?
  shopId             String
  creditLimit        Decimal   @default(5000) @db.Decimal(10, 2)
  outstandingBalance Decimal   @default(0) @db.Decimal(10, 2)
  totalPurchases     Decimal   @default(0) @db.Decimal(10, 2)
  totalPaid          Decimal   @default(0) @db.Decimal(10, 2)
  lastPurchaseAt     DateTime?
  lastPaymentAt      DateTime?
  tags               String?
  notes              String?
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  isDeleted          Boolean   @default(false)
  deletedAt          DateTime?

  shop              Shop               @relation(fields: [shopId], references: [id], onDelete: Restrict)
  invoices          Invoice[]
  udharTransactions UdharTransaction[]

  @@unique([shopId, phone, deletedAt])
  @@index([shopId])
}

model Shift {
  id            String      @id @default(cuid())
  shopId        String
  openedById    String
  closedById    String?
  openingCash   Decimal     @db.Decimal(10, 2)
  closingCash   Decimal?    @db.Decimal(10, 2)
  expectedCash  Decimal     @default(0) @db.Decimal(10, 2)
  totalSales    Decimal     @default(0) @db.Decimal(10, 2)
  totalReceipts Decimal     @default(0) @db.Decimal(10, 2)
  cashSales     Decimal     @default(0) @db.Decimal(10, 2)
  upiSales      Decimal     @default(0) @db.Decimal(10, 2)
  cardSales     Decimal     @default(0) @db.Decimal(10, 2)
  udharSales    Decimal     @default(0) @db.Decimal(10, 2)
  status        ShiftStatus @default(OPEN)
  openedAt      DateTime    @default(now())
  closedAt      DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  isDeleted     Boolean     @default(false)
  deletedAt     DateTime?

  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Restrict)
  openedBy User      @relation("ShiftOpenedBy", fields: [openedById], references: [id], onDelete: Restrict)
  closedBy User?     @relation("ShiftClosedBy", fields: [closedById], references: [id], onDelete: Restrict)
  invoices Invoice[]

  @@index([shopId, status])
  @@index([openedById])
  @@index([closedById])
  @@index([shopId, openedAt])
}

model Invoice {
  id             String        @id @default(cuid())
  invoiceNumber  String
  idempotencyKey String
  financialYear  String
  shopId         String
  customerId     String?
  cashierId      String
  originalId     String?
  subtotal       Decimal       @db.Decimal(10, 2)
  taxableAmount  Decimal       @db.Decimal(10, 2)
  cgstAmount     Decimal       @db.Decimal(10, 2)
  sgstAmount     Decimal       @db.Decimal(10, 2)
  igstAmount     Decimal       @default(0) @db.Decimal(10, 2)
  taxAmount      Decimal       @db.Decimal(10, 2)
  discountAmount Decimal       @db.Decimal(10, 2)
  roundOffAmount Decimal       @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal       @db.Decimal(10, 2)
  paidAmount     Decimal       @db.Decimal(10, 2)
  udharAmount    Decimal       @default(0) @db.Decimal(10, 2)
  changeAmount   Decimal       @db.Decimal(10, 2)
  paymentMode    PaymentMode
  paymentRef     String?
  isInterState   Boolean       @default(false)
  type           InvoiceType   @default(SALE)
  status         InvoiceStatus
  cancelReason   String?
  notes          String?
  shiftId        String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  isDeleted      Boolean       @default(false)
  deletedAt      DateTime?

  shop               Shop                @relation(fields: [shopId], references: [id], onDelete: Restrict)
  customer           Customer?           @relation(fields: [customerId], references: [id], onDelete: Restrict)
  cashier            User                @relation("InvoiceCashier", fields: [cashierId], references: [id], onDelete: Restrict)
  shift              Shift?              @relation(fields: [shiftId], references: [id], onDelete: Restrict)
  items              InvoiceItem[]
