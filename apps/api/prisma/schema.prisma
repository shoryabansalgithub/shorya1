generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  OWNER
  ADMIN
  MANAGER
  CASHIER
  VIEWER
}

enum ShopStatus {
  ACTIVE
  SUSPENDED
  LOCKED
  ARCHIVED
  DELETED
}

enum PaymentMode {
  CASH
  UPI
  CARD
  UDHAR
  SPLIT
}

enum InvoiceType {
  SALE
  SALES_RETURN
}

enum InvoiceStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

enum UdharTransactionType {
  CREDIT
  PAYMENT
  ADJUSTMENT
  WRITEOFF
}

enum InventoryChangeType {
  SALE
  PURCHASE
  RETURN_IN
  RETURN_OUT
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
  DAMAGE
  OPENING
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  BILLED
  CLOSED
  REJECTED
  CANCELLED
  ARCHIVED
}

enum StockTransferStatus {
  PENDING
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

