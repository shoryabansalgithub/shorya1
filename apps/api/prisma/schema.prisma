enum BarcodeFormat {
  GS1
  EAN8
  EAN13
  UPCA
  UPCE
  CODE39
  CODE93
  CODE128
  ITF
  ITF14
  CODABAR
  MSI
  PHARMACODE
  QRCODE
  DATAMATRIX
  PDF417
  AZTEC
}

enum BarcodeStatus {
  ACTIVE
  INACTIVE
  REVOKED
  EXPIRED
}

enum DriftStatus {
  DETECTED
  REPAIRED
  FAILED
