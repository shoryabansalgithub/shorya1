generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  CASHIER
  VIEWER
}

enum Unit {
  PCS
  KG
  GM
  LTR
  ML
  BOX
  PACK
  DOZEN
}

enum PaymentMode {
  CASH
  UPI
  CARD
  UDHAR
  SPLIT
}

enum InvoiceStatus {
  DRAFT
  COMPLETED
  CANCELLED
  RETURNED
}

enum TransactionType {
  CREDIT
  PAYMENT
  ADJUSTMENT
}

enum InventoryLogType {
  SALE
  PURCHASE
  ADJUSTMENT
  RETURN
  TRANSFER
}

enum ShiftStatus {
  OPEN
  CLOSED
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  password       String
  name           String
  phone          String?
  role           Role
  isActive       Boolean   @default(true)
  shopId         String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  isDeleted      Boolean   @default(false)
  isLocked       Boolean   @default(false)
  lockedUntil    DateTime?
  lastLoginAt    DateTime?
  lastLoginIp    String?
  failedAttempts Int       @default(0)

  shop              Shop?              @relation("ShopOwner")
  shopEmployee      Shop?              @relation("ShopEmployees", fields: [shopId], references: [id], onDelete: Restrict)
  invoices          Invoice[]
  udharTransactions UdharTransaction[]
  inventoryLogs     InventoryLog[]
  shiftsOpened      Shift[]            @relation("ShiftOpenedBy")
  shiftsClosed      Shift[]            @relation("ShiftClosedBy")
  auditLogs         AuditLog[]
  refreshTokens     RefreshToken[]

  @@index([shopId])
}

model Shop {
  id        String   @id @default(cuid())
  name      String
  address   String?
  city      String?
  state     String?
  pincode   String?
  phone     String?
  email     String?
  gstin     String?
  logoUrl   String?
  currency  String   @default("INR")
  timezone  String   @default("Asia/Kolkata")
  isActive  Boolean  @default(true)
  ownerId   String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)

  owner             User               @relation("ShopOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  employees         User[]             @relation("ShopEmployees")
  products          Product[]
  categories        Category[]
  customers         Customer[]
  invoices          Invoice[]
  udharTransactions UdharTransaction[]
  inventoryLogs     InventoryLog[]
  shifts            Shift[]
  auditLogs         AuditLog[]
}

model Product {
  id           String   @id @default(cuid())
  name         String
  sku          String
  barcode      String?
  description  String?
  costPrice    Decimal  @db.Decimal(10, 2)
  sellingPrice Decimal  @db.Decimal(10, 2)
  mrp          Decimal  @db.Decimal(10, 2)
  gstRate      Float    @default(18)
  hsnCode      String?
  categoryId   String?
  shopId       String
  currentStock Int      @default(0)
  reorderPoint Int      @default(10)
  reorderQty   Int      @default(50)
  unit         Unit
  isActive     Boolean  @default(true)
  imageUrl     String?
  aliases      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  isDeleted    Boolean  @default(false)

  shop          Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  category      Category?      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  invoiceItems  InvoiceItem[]
  inventoryLogs InventoryLog[]

  @@unique([shopId, sku])
  @@index([shopId, categoryId])
}

model Category {
  id        String   @id @default(cuid())
  name      String
  shopId    String
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)

  shop          Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  parent        Category?  @relation("SubCategories", fields: [parentId], references: [id], onDelete: Restrict)
  subCategories Category[] @relation("SubCategories")
  products      Product[]
}

model Customer {
  id                 String    @id @default(cuid())
  name               String
  phone              String
  email              String?
  address            String?
  city               String?
  shopId             String
  creditLimit        Decimal   @default(5000) @db.Decimal(10, 2)
  outstandingBalance Decimal   @default(0) @db.Decimal(10, 2)
  totalPurchases     Decimal   @default(0) @db.Decimal(10, 2)
  lastPurchaseAt     DateTime?
  notes              String?
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  isDeleted          Boolean   @default(false)

  shop              Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  invoices          Invoice[]
  udharTransactions UdharTransaction[]

  @@unique([shopId, phone])
  @@index([shopId, phone])
}

model Invoice {
  id             String        @id @default(cuid())
  invoiceNumber  String
  shopId         String
  customerId     String?
  cashierId      String
  subtotal       Decimal       @db.Decimal(10, 2)
  taxAmount      Decimal       @db.Decimal(10, 2)
  discountAmount Decimal       @db.Decimal(10, 2)
  totalAmount    Decimal       @db.Decimal(10, 2)
  paidAmount     Decimal       @db.Decimal(10, 2)
  changeAmount   Decimal       @db.Decimal(10, 2)
  paymentMode    PaymentMode
  status         InvoiceStatus
  notes          String?
  shiftId        String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  isDeleted      Boolean       @default(false)

  shop              Shop               @relation(fields: [shopId], references: [id], onDelete: Restrict)
  customer          Customer?          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  cashier           User               @relation(fields: [cashierId], references: [id], onDelete: Restrict)
  shift             Shift?             @relation(fields: [shiftId], references: [id], onDelete: Restrict)
  items             InvoiceItem[]
  udharTransactions UdharTransaction[]
  inventoryLogs     InventoryLog[]

  @@unique([shopId, invoiceNumber])
  @@index([shopId, status])
  @@index([customerId])
}

model InvoiceItem {
  id              String   @id @default(cuid())
  invoiceId       String
  productId       String
  productName     String
  productSku      String
  quantity        Float
  unit            String
  costPrice       Decimal  @db.Decimal(10, 2)
  sellingPrice    Decimal  @db.Decimal(10, 2)
  mrp             Decimal  @db.Decimal(10, 2)
  discountPercent Float    @default(0)
  gstRate         Float
  cgstAmount      Decimal  @db.Decimal(10, 2)
  sgstAmount      Decimal  @db.Decimal(10, 2)
  igstAmount      Decimal  @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal  @db.Decimal(10, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  isDeleted       Boolean  @default(false)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
}

model UdharTransaction {
  id            String          @id @default(cuid())
  customerId    String
  invoiceId     String?
  shopId        String
  type          TransactionType
  amount        Decimal         @db.Decimal(10, 2)
  balanceBefore Decimal         @db.Decimal(10, 2)
  balanceAfter  Decimal         @db.Decimal(10, 2)
  notes         String?
  recordedById  String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  isDeleted     Boolean         @default(false)

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  invoice    Invoice? @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  shop       Shop     @relation(fields: [shopId], references: [id], onDelete: Restrict)
  recordedBy User     @relation(fields: [recordedById], references: [id], onDelete: Restrict)
}

model InventoryLog {
  id             String           @id @default(cuid())
  productId      String
  shopId         String
  type           InventoryLogType
  quantityBefore Int
  quantityChange Int
  quantityAfter  Int
  invoiceId      String?
  notes          String?
  recordedById   String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  isDeleted      Boolean          @default(false)

  product    Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  shop       Shop     @relation(fields: [shopId], references: [id], onDelete: Restrict)
  invoice    Invoice? @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  recordedBy User     @relation(fields: [recordedById], references: [id], onDelete: Restrict)
}

model Shift {
  id           String      @id @default(cuid())
  shopId       String
  openedById   String
  closedById   String?
  openingCash  Decimal     @db.Decimal(10, 2)
  closingCash  Decimal?    @db.Decimal(10, 2)
  expectedCash Decimal     @default(0) @db.Decimal(10, 2)
  status       ShiftStatus @default(OPEN)
  openedAt     DateTime    @default(now())
  closedAt     DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  isDeleted    Boolean     @default(false)

  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Restrict)
  openedBy User      @relation("ShiftOpenedBy", fields: [openedById], references: [id], onDelete: Restrict)
  closedBy User?     @relation("ShiftClosedBy", fields: [closedById], references: [id], onDelete: Restrict)
  invoices Invoice[]
}

model AuditLog {
  id         String   @id @default(cuid())
  shopId     String
  userId     String
  action     String
  entity     String
  entityId   String
  beforeData Json?
  afterData  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  isDeleted  Boolean  @default(false)

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Restrict)
  user User @relation(fields: [userId], references: [id], onDelete: Restrict)
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ipAddress String
  success   Boolean
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
}
