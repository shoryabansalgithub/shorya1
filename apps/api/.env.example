################################################################################
# DUKAN AI ENTERPRISE ENVIRONMENT FILE
################################################################################

################################################################################
# APPLICATION
################################################################################
NODE_ENV=development
PORT=3002
FRONTEND_URL=http://localhost:3000

################################################################################
# DATABASE
################################################################################
DATABASE_URL=mysql://root:password@localhost:3306/dukaanai
PRISMA_LOG_QUERIES=true
PRISMA_SLOW_QUERY_THRESHOLD=1000

################################################################################
# REDIS / QUEUE
################################################################################
REDIS_URL=redis://localhost:6379
QUEUE_CONCURRENCY=5
QUEUE_TIMEOUT=5000
CACHE_TTL=3600000
CACHE_MAX_ITEMS=1000

################################################################################
# AUTHENTICATION
################################################################################
JWT_SECRET=your_jwt_secret_generate_with_openssl
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=your_refresh_secret_generate_with_openssl
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# DANGER: set to true ONLY to run the app with authentication fully disabled.
# Every request then runs as a provisioned system user (system@dukaanai.local)
# and the API logs a loud warning at startup. Accepts only true/1/yes/on (or
# false/0/no/off); an unrecognized value refuses to boot. Defaults to false
# (auth enabled) when unset. Never enable in production.
AUTH_DISABLED=false

################################################################################
# SECURITY
################################################################################
SECURITY_MAX_LOGIN_ATTEMPTS=5
SECURITY_LOCKOUT_DURATION_MS=900000
RATE_LIMIT_SHORT_TTL=10
RATE_LIMIT_SHORT_LIMIT=20
RATE_LIMIT_MEDIUM_TTL=60
RATE_LIMIT_MEDIUM_LIMIT=100
RATE_LIMIT_LONG_TTL=3600
RATE_LIMIT_LONG_LIMIT=1000
AUTH_RATE_LIMIT_SHORT_LIMIT=5
AUTH_RATE_LIMIT_MEDIUM_LIMIT=20
AUTH_RATE_LIMIT_LONG_LIMIT=100

################################################################################
# STORAGE
################################################################################
STORAGE_ROOT=./data/storage
S3_REGION=us-east-1
S3_ENDPOINT=
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_BUCKET=your_bucket
S3_PUBLIC_URL=https://cdn.example.com

################################################################################
# AI / OCR
################################################################################
GEMINI_API_KEY=your_gemini_api_key
OCR_FUZZY_MATCH_THRESHOLD=0.85
OCR_TIMEOUT_MS=30000
OCR_BACKOFF_MS=1000

################################################################################
# FEATURE FLAGS & TUNING
################################################################################
EVENTS_RECENT_LIMIT=50
EVENTS_WEBHOOK_DELIVERY_LIMIT=5
EVENTS_OUTBOX_PROCESSOR_BATCH_SIZE=100
IMPORT_EXPORT_LIST_LIMIT=50
INVENTORY_RECENT_ADJUSTMENTS_LIMIT=100
INVENTORY_RECENT_MOVEMENTS_LIMIT=100
INVENTORY_UNRESOLVED_ALERTS_LIMIT=50
INVENTORY_LIST_LIMIT=50
INVENTORY_RECON_BATCH_SIZE=1000
INVENTORY_RECON_LOCK_TTL_MS=300000
INVENTORY_MAX_PRINT_QUANTITY=1000
INVENTORY_RECON_LOOKBACK_MS=86400000
PURCHASE_DEAD_LETTER_PAGINATION_LIMIT=50
SALES_DEFAULT_PAGINATION_LIMIT=50
SALES_RECENT_EVENTS_LIMIT=100
SALES_CREDIT_HOLD_THRESHOLD=10000
SALES_DEFAULT_CREDIT_LIMIT=5000
SEARCH_FUZZY_CANDIDATE_LIMIT=100
SEARCH_RESULT_LIMIT=50
SEARCH_ANALYTICS_LIMIT=1000
VALIDATION_DUPLICATE_SCAN_LIMIT=10
VENDOR_BILL_PROCESSOR_DELAY_MS=5000
GRN_PROCESSOR_BARCODE_DELAY_MS=1000
GRN_PROCESSOR_ATTACHMENT_DELAY_MS=2000
SUPPLIER_CREDIT_PROCESSOR_DELAY_MS=3000
PURCHASE_RETURN_PROCESSOR_DELAY_MS=3000
PURCHASE_ATTACHMENT_PROCESSOR_DELAY_MS=2000
