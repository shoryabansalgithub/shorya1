# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  DukanAI Enterprise ERP — API Server Configuration                        ║
# ║  ENV-1 Foundation v1.0 | Classification: EXAMPLE (safe to commit)          ║
# ║                                                                            ║
# ║  ONBOARDING:                                                               ║
# ║    1. Copy this file → .env.local                                          ║
# ║    2. Fill in all values marked [REQUIRED]                                 ║
# ║    3. Run: npm run dev                                                     ║
# ║                                                                            ║
# ║  SECURITY CLASSIFICATION LEGEND:                                           ║
# ║    [Public]    — Safe to expose in logs, docs, client bundles              ║
# ║    [Internal]  — Not secret, but should not be public-facing               ║
# ║    [Sensitive] — API keys, tokens with limited blast radius                ║
# ║    [Critical]  — Signing keys, DB credentials, encryption keys             ║
# ║                                                                            ║
# ║  PRECEDENCE (highest → lowest):                                            ║
# ║    .env.local > .env.{NODE_ENV} > .env                                     ║
# ║                                                                            ║
# ║  DOCS: docs/architecture/environment-architecture.md                       ║
# ╚══════════════════════════════════════════════════════════════════════════════╝


# ═══════════════════════════════════════════════════════════════════════════════
# APPLICATION
# Owner: Platform Team
# ═══════════════════════════════════════════════════════════════════════════════

# [Public] Runtime environment — controls Swagger, log verbosity, Prisma query logging
# Valid values: development | test | production
NODE_ENV=development

# [Public] HTTP port for the NestJS API server
# Default: 3002
PORT=3002

# [Public] Comma-separated list of allowed CORS origins
# Used by: main.ts (Express CORS), inventory.gateway.ts (WebSocket CORS)
# Example production: https://app.dukan.ai,https://admin.dukan.ai
# [REQUIRED]
FRONTEND_URL=http://localhost:3000


# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE (Prisma / MySQL)
# Owner: Data Platform Team
# ═══════════════════════════════════════════════════════════════════════════════

# [Critical] MySQL connection string — used by Prisma ORM
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Requirements: User must have CREATE TRIGGER and DROP TRIGGER privileges
# See: ENVIRONMENT_REQUIREMENTS.md §1
# [REQUIRED]
DATABASE_URL="mysql://root:CHANGE_ME@localhost:3306/dukaanai"


# ═══════════════════════════════════════════════════════════════════════════════
# AUTHENTICATION (JWT)
# Owner: Security Team
# ═══════════════════════════════════════════════════════════════════════════════

# [Critical] JWT signing secret for access tokens
# Used by: AuthModule, JwtStrategy, InventoryModule, AuthenticatedIoAdapter
# Generate: openssl rand -hex 32
# Minimum length: 32 characters
# [REQUIRED]
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# [Internal] Access token expiration duration
# Format: https://github.com/vercel/ms (e.g., 1d, 12h, 30m)
# Default: 1d
JWT_EXPIRES_IN=1d

# [Critical] JWT signing secret for refresh tokens
# Must be DIFFERENT from JWT_SECRET
# Generate: openssl rand -hex 32
# [REQUIRED]
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# [Internal] Refresh token expiration duration
# Default: 7d
JWT_REFRESH_EXPIRES_IN=7d


# ═══════════════════════════════════════════════════════════════════════════════
# REDIS / BullMQ
# Owner: Platform Team
# ═══════════════════════════════════════════════════════════════════════════════

# [Sensitive] Redis connection URL for caching, BullMQ job queues, and distributed locks
# Used by: CacheModule, BullModule.forRootAsync, CronLockService, SalesRedisBroadcaster
# Queues: 27 registered BullMQ queues depend on this connection
# Optional: App runs in degraded mode without Redis (local memory cache, no distributed locks)
# Format: redis://[:password@]host:port[/db]
# See: ENVIRONMENT_REQUIREMENTS.md §2
REDIS_URL=


# ═══════════════════════════════════════════════════════════════════════════════
# STORAGE (Local Filesystem)
# Owner: Platform Team
# ═══════════════════════════════════════════════════════════════════════════════

# [Internal] Root directory for tenant-isolated local file storage
# Used by: StoragePathBuilder — all file operations are scoped under this path
# Default: {cwd}/data/storage
# Anti-traversal: StoragePathBuilder enforces path.resolve checks
STORAGE_ROOT=


# ═══════════════════════════════════════════════════════════════════════════════
# STORAGE (S3 / Cloud Object Storage)
# Owner: Infrastructure Team
# ═══════════════════════════════════════════════════════════════════════════════

# [Internal] AWS region for the S3 bucket
# Default: auto
S3_REGION=

# [Internal] S3-compatible endpoint URL
# Use for non-AWS providers (e.g., MinIO, Cloudflare R2, DigitalOcean Spaces)
# Leave blank for standard AWS S3
S3_ENDPOINT=

# [Sensitive] AWS access key ID for S3 operations
S3_ACCESS_KEY=

# [Critical] AWS secret access key for S3 operations
# NEVER log or expose this value
S3_SECRET_KEY=

# [Internal] Target S3 bucket name
S3_BUCKET=

# [Public] Public-facing CDN URL for uploaded assets
# Used to construct file download URLs returned to clients
# Example: https://cdn.dukan.ai
S3_PUBLIC_URL=


# ═══════════════════════════════════════════════════════════════════════════════
# AI / OCR (Google Gemini)
# Owner: AI/ML Team
# ═══════════════════════════════════════════════════════════════════════════════

# [Sensitive] Google Gemini API key for OCR document processing
# Used by: OcrService — Gemini 1.5 Flash for invoice/bill parsing
# Optional: OCR endpoints return error if not set
GEMINI_API_KEY=


# ═══════════════════════════════════════════════════════════════════════════════
# FUTURE PLACEHOLDERS (ENV-2)
# The following domains are reserved for future configuration.
# Do NOT add variables here until the module is implemented.
# ═══════════════════════════════════════════════════════════════════════════════
# EMAIL        — SMTP/SendGrid/SES configuration
# SMS          — Twilio/SNS configuration
# WHATSAPP     — WhatsApp Business API
# PAYMENTS     — Razorpay/Stripe gateway credentials
# MONITORING   — Sentry DSN, Datadog API keys
# LOGGING      — Log level, structured logging format
# FEATURE_FLAGS — LaunchDarkly/Unleash/custom flags
