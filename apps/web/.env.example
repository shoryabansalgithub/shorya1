################################################################################
# DUKAN AI FRONTEND ENVIRONMENT FILE
################################################################################

################################################################################
# APPLICATION
################################################################################
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3002/api

################################################################################
# AUTHENTICATION
################################################################################
NEXTAUTH_SECRET=your_nextauth_secret_generate_with_openssl
NEXTAUTH_URL=http://localhost:3000

# DANGER: set to true ONLY to skip the login gate entirely (pair with the
# API's AUTH_DISABLED=true). Inlined at build time - set it before `next build`.
# Defaults to false (login required) when unset.
NEXT_PUBLIC_AUTH_DISABLED=false

################################################################################
# OAUTH
################################################################################
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
