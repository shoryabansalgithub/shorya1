# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  DukanAI Enterprise ERP — Web (Next.js) Configuration                     ║
# ║  ENV-1 Foundation v1.0 | Classification: EXAMPLE (safe to commit)          ║
# ║                                                                            ║
# ║  ONBOARDING:                                                               ║
# ║    1. Copy this file → .env.local                                          ║
# ║    2. Fill in all values marked [REQUIRED]                                 ║
# ║    3. Run: npm run dev                                                     ║
# ║                                                                            ║
# ║  NEXT.JS ENV RULES:                                                        ║
# ║    • NEXT_PUBLIC_* → Exposed to browser (bundled into client JS)           ║
# ║    • All others    → Server-side only (API routes, SSR)                    ║
# ║                                                                            ║
# ║  PRECEDENCE (Next.js built-in):                                            ║
# ║    .env.local > .env.{NODE_ENV} > .env                                     ║
# ║                                                                            ║
# ║  DOCS: docs/architecture/environment-architecture.md                       ║
# ╚══════════════════════════════════════════════════════════════════════════════╝


# ═══════════════════════════════════════════════════════════════════════════════
# APPLICATION
# Owner: Frontend Team
# ═══════════════════════════════════════════════════════════════════════════════

# [Public] API base URL — exposed to the browser via NEXT_PUBLIC_ prefix
# Used by: lib/api.ts (Axios client), lib/auth.ts (backend provisioning)
# Must include the /api path prefix
# Example production: https://api.dukan.ai/api
NEXT_PUBLIC_API_URL=http://localhost:3002/api


# ═══════════════════════════════════════════════════════════════════════════════
# AUTHENTICATION (NextAuth.js)
# Owner: Security Team
# ═══════════════════════════════════════════════════════════════════════════════

# [Critical] NextAuth JWT encryption secret
# Used by: NextAuth session encryption, JWT cookie signing
# Generate: openssl rand -hex 32
# Minimum length: 32 characters
# [REQUIRED]
NEXTAUTH_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# [Public] Canonical URL for NextAuth callbacks and redirects
# Must match the deployed URL exactly (protocol + domain + port)
# Default: http://localhost:3000
NEXTAUTH_URL=http://localhost:3000


# ═══════════════════════════════════════════════════════════════════════════════
# OAUTH PROVIDERS (Google)
# Owner: Security Team
# ═══════════════════════════════════════════════════════════════════════════════

# [Sensitive] Google OAuth 2.0 client ID
# Obtain from: https://console.cloud.google.com/apis/credentials
# Required only if Google sign-in is enabled
GOOGLE_CLIENT_ID=

# [Critical] Google OAuth 2.0 client secret
# NEVER expose to client-side code (no NEXT_PUBLIC_ prefix)
# Required only if Google sign-in is enabled
GOOGLE_CLIENT_SECRET=


# ═══════════════════════════════════════════════════════════════════════════════
# FUTURE PLACEHOLDERS (ENV-2)
# ═══════════════════════════════════════════════════════════════════════════════
# NEXT_PUBLIC_WS_URL       — WebSocket endpoint for real-time features
# NEXT_PUBLIC_CDN_URL      — Static asset CDN
# NEXT_PUBLIC_ANALYTICS_ID — Google Analytics / Mixpanel
# SENTRY_DSN               — Error tracking (server-side)
